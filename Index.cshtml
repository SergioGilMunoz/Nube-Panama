                                                                                <p class="mb-1 small"><i class="fas fa-envelope me-1"></i>${client.email || '<span class="badge bg-secondary bg-opacity-50 small">No correo</span>'}</p>
                                                                                <p class="text-muted mb-0 small"><i class="fas fa-phone me-1"></i>${client.telefono || '<span class="badge bg-secondary bg-opacity-50 small">No teléfono</span>'}</p>
