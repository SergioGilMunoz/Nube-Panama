        // ========================
        // 3. PROCESAR LOS ARCHIVOS SELECCIONADOS
        // ========================
        function whspHandleFiles(files) {
            // Convierte FileList a array y procesa cada archivo
            Array.from(files).forEach(file => {
                whspUploadFile(file);
            });

            // Oculta el área de arrastre después de seleccionar
            const fileUploadArea = document.getElementById('whspFileUploadArea');
            if (fileUploadArea) {
                fileUploadArea.style.display = 'none';
            }
        }



        function whspUploadFile(file) {
            // ✅ Validar tamaño (25MB máximo)
            const maxSize = 25 * 1024 * 1024; // 25MB en bytes
            if (file.size > maxSize) {
                alert('❌ El archivo es muy grande. Máximo 25MB.');
                return;
            }

            // ✅ Evitar múltiples envíos simultáneos
            if (whspSending) {
                console.warn('⏳ Ya se está enviando un archivo...');
                return;
            }

            whspSending = true;

            // ✅ Mostrar "cargando" en el área de subida
            const fileUploadArea = document.getElementById('whspFileUploadArea');
            if (fileUploadArea) {
                fileUploadArea.innerHTML = '<i class="fas fa-spinner fa-spin fa-2x text-primary mb-2"></i><p>Subiendo...</p>';
                fileUploadArea.style.display = 'block';
            }

            // ✅ Leer archivo como Base64
            const reader = new FileReader();
            reader.onload = function (e) {
                const base64Data = e.target.result.split(',')[1]; // Solo la parte Base64
                const currentTime = new Date().toLocaleString('es-ES', {
                    day: '2-digit',
                    month: 'short',
                    year: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit'
                });

                // ✅ Datos que se enviarán al servidor
                const chatMessageData = {
                    from_Id: "1",
                    to_Id: "2",
                    mensaje: `📎 ${file.name}`,
                    datetime: currentTime,
                    archivoBase64: base64Data,
                    nombreArchivo: file.name,
                    tipoArchivo: file.type,
                    tamanoArchivo: file.size
                };

                let telefono = document.getElementById("whspClientPhone").value;

                const payload = {
                    idCliente: whspCurrentClientData.idCliente,
                    IdPersonal: whspCurrentClientData.idParaMensajeria,
                    Telefono: telefono,
                    nombrePersonal: whspCurrentClientData.personalNombre,
                    ChatMessageData: chatMessageData
                };

                // ✅ Enviar al servidor
                fetch('/DashboardRerservas/EnviarArchivoPersonalCliente', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify(payload)
                })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // ✅ Mostrar archivo en el chat (vista previa)
                            const fileMessage = whspCreateFileMessage(file, e.target.result);
                            whspAddMyMessage(fileMessage, true); // `true` indica que es un archivo



                            // ✅ Actualizar estadísticas
                            whspMessageCount++;
                            whspUpdateStats();

                            // ✅ Simular confirmación del cliente (opcional)
                            setTimeout(() => {
                                whspAddClientMessage("He recibido tu archivo 👍");
                            }, 1000);
                        } else {
                            alert('❌ Error al enviar archivo: ' + (data.message || 'Desconocido'));
                        }
                    })
                    .catch(error => {
                        console.error('❌ Error al enviar archivo:', error);
                        alert('Error de conexión. No se pudo enviar el archivo.');
                    })
                    .finally(() => {
                        // ✅ Resetear estado
                        if (fileUploadArea) {
                            fileUploadArea.style.display = 'none';
                            fileUploadArea.innerHTML = `
                                                    <i class="fas fa-cloud-upload-alt fa-2x text-success mb-2"></i>
                                                    <p class="mb-0">Suelta aquí tu archivo o <strong>haz clic para seleccionar</strong></p>
                                                    <small class="text-muted">Máximo 25MB - Imágenes, videos, documentos</small>
                                                `;
                        }
                        whspSending = false;
                    });
            };

            // ✅ Iniciar lectura del archivo
            reader.readAsDataURL(file);
        }


        // para imagenes
