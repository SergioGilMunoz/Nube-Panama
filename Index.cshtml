        function whspCreateFileMessage(file, dataUrl) {
            const size = file.size || file.tamanoArchivo || 0;
            const fileName = file.name || file.nombreArchivo || 'Imagen';

            if (file.type && file.type.startsWith('image/')) {
                return `
                <div class="mb-1 position-relative">
                    <a href="${dataUrl}"
                       data-pswp-src="${dataUrl}"
                       target="_blank"
                       style="display: inline-block;" data-pswp-width="500" data-pswp-height="800" >
                        <img src="${dataUrl}"
                             class="whsp-file-preview"
                             style="max-width: 200px; border-radius: 8px; cursor: zoom-in;"
                             alt="${fileName}"
                             title="Clic para ver en grande">
                    </a>
                    <i class="fas fa-download position-absolute"
                       style="top: 5px; right: 5px; background: rgba(0,0,0,0.7); color: white; padding: 4px; border-radius: 50%; font-size: 10px; cursor: pointer;"
                       onclick="whspDownloadImage('${dataUrl}', '${fileName}')"
                       title="Descargar imagen">
                    </i>
                </div>
               <small class="text-muted" title="${fileName}">${fileName.length > 10 ? fileName.substring(0, 10) + '...' : fileName}</small>`;
            }


            // ✅ Video: reproductor
            else if (file.type && file.type.startsWith('video/')) {
                return `
                                     <div class="mb-1">
                                         <video controls class="whsp-file-preview" style="max-width: 250px; border-radius: 8px;">
                                             <source src="${dataUrl}" type="${file.type}">
                                             Tu navegador no soporta videos.
                                         </video>
                                     </div>
                                     <small class="text-muted">${file.name || file.nombreArchivo || 'Video'}</small>`;
            }

            // ✅ Documento: icono según tipo
            else {
                const icon = whspGetFileIcon(file.type);
                const formattedSize = whspFormatFileSize(size);
                const fileName = file.name || file.nombreArchivo || 'Archivo';

                return `
                                     <div class="d-flex align-items-center bg-light p-3 rounded shadow-sm" style="max-width: 300px;">
                                         <i class="${icon} me-3" style="font-size: 24px;"></i>
                                         <div>
                                             <strong>${fileName}</strong><br>
                                             <small class="text-muted">${formattedSize}</small>
                                         </div>
                                     </div>`;
            }
        }



        // ✅ Obtener icono según tipo de archivo
        function whspGetFileIcon(fileType) {
            if (fileType.includes('pdf')) return 'fas fa-file-pdf text-danger';
            if (fileType.includes('word') || fileType.includes('doc')) return 'fas fa-file-word text-primary';
            if (fileType.includes('excel') || fileType.includes('sheet')) return 'fas fa-file-excel text-success';
            if (fileType.includes('text') || fileType.includes('txt')) return 'fas fa-file-alt text-secondary';
            return 'fas fa-file text-secondary';
        }

        // ✅ Formatear tamaño de archivo
        function whspFormatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }


        // ========================
        // DRAG & DROP, BUSQUEDA, EMOJIS
        // ========================
        function whspInitializeDragDrop() {
            const windowEl = document.getElementById('whspWindow');
            const header = document.getElementById('whspDragHandle');
            const chatContainer = document.getElementById('whspMessagesArea');
            const fileUploadArea = document.getElementById('whspFileUploadArea');

            if (!windowEl || !header || !chatContainer || !fileUploadArea) {
                setTimeout(whspInitializeDragDrop, 100);
                return;
            }

            let isDragging = false;
            let startX, startY, initialX, initialY;

            // === DRAG DEL MODAL ===
            header.addEventListener('mousedown', (e) => {
                isDragging = true;
                startX = e.clientX;
                startY = e.clientY;
                const rect = windowEl.getBoundingClientRect();
                initialX = rect.left;
                initialY = rect.top;
                header.style.cursor = 'grabbing';
            });

            document.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                const deltaX = e.clientX - startX;
                const deltaY = e.clientY - startY;
                let newX = initialX + deltaX;
                let newY = initialY + deltaY;
                newX = Math.max(0, Math.min(newX, window.innerWidth - windowEl.offsetWidth));
                newY = Math.max(0, Math.min(newY, window.innerHeight - windowEl.offsetHeight));
                windowEl.style.position = 'fixed';
                windowEl.style.left = newX + 'px';
                windowEl.style.top = newY + 'px';
                document.getElementById('whspWindowContainer').style.alignItems = 'flex-start';
                document.getElementById('whspWindowContainer').style.justifyContent = 'flex-start';
            });

            document.addEventListener('mouseup', () => {
                isDragging = false;
                header.style.cursor = 'move';
            });

            // === DRAG & DROP DE ARCHIVOS ===
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(event => {
                chatContainer.addEventListener(event, e => {
                    e.preventDefault();
                    e.stopPropagation();
                });
            });

            // Mostrar área de carga SOLO cuando entra un archivo
            chatContainer.addEventListener('dragenter', () => {
                document.getElementById('whspFileUploadArea').classList.add('drag-over');
                document.getElementById('whspFileUploadArea').style.display = 'flex'; // Mostrar solo aquí
            });

            chatContainer.addEventListener('dragover', () => {
                document.getElementById('whspFileUploadArea').classList.add('drag-over');
            });

            chatContainer.addEventListener('dragleave', (e) => {
                // Verificar que el ratón salió del contenedor
                if (!chatContainer.contains(e.relatedTarget)) {
                    document.getElementById('whspFileUploadArea').classList.remove('drag-over');
                    document.getElementById('whspFileUploadArea').style.display = 'none';
                }
            });

            chatContainer.addEventListener('drop', (e) => {
                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    whspHandleFiles(files);
                }
                document.getElementById('whspFileUploadArea').classList.remove('drag-over');
                document.getElementById('whspFileUploadArea').style.display = 'none';
            });

            // Click para abrir el selector de archivos
            document.getElementById('whspFileUploadArea').addEventListener('click', () => {
                document.getElementById('whspFileInput').click();
            });
        }


