        //personal


        function showRealPersonalModal(clientName, clienteData) {
            // Cambiar el ID del elemento para la ventana
            document.getElementById('client-name-window').textContent = clientName;

            const personalMap = new Map();

            // Procesar personal de reservas
            clienteData.personal.forEach(personal => {
                if (personal.personal_reservas) {
                    const pr = personal.personal_reservas;
                    const reservas = pr.reservas;
                    const ventasTotales = reservas.reconfirmado.reduce((sum, r) => sum + r.total, 0);

                    personalMap.set(pr.nombre_completo, {
                        nombre: pr.nombre_completo,
                        estadoDatos: pr.estado_actualizacion,
                        email: pr.correo_personal_reserva,
                        telefono: pr.telefono_personal_reserva2 || pr.telefono_personal_reserva || 'N/A',
                        ventasTotales,
                        id_cliente: clienteData.id_cliente,
                        id_personal_reserva: pr.id_personal_reserva,
                        id_personal_cotizacion: null,
                        personalData: personal,
                        tieneReservas: true,
                        tieneCotizaciones: false,
                        totalCotizaciones: 0,
                        cargo_personal_reserva:pr.cargo_personal_reserva
                    });
                }
            });

            // Procesar personal de cotizaciones
            clienteData.personal.forEach(personal => {
                if (personal.personal_cotizaciones) {
                    const pc = personal.personal_cotizaciones;
                    const totalCotizaciones = pc.cotizaciones.length;

                    if (personalMap.has(pc.nombre_completo)) {
                        // Ya existe, agregar datos de cotizaciones
                        const existing = personalMap.get(pc.nombre_completo);
                        existing.id_personal_cotizacion = pc.id_personal_cotizacion;
                        existing.tieneCotizaciones = true;
                        existing.totalCotizaciones = totalCotizaciones;

                        existing.cargo_personal_cotizacion = pc.cargo_personal_cotizacion; 

                        // Combinar datos del personal
                        existing.personalData = {
                            personal_reservas: existing.personalData.personal_reservas,
                            personal_cotizaciones: personal.personal_cotizaciones
                        };
                    } else {
