        // Función para cargar historial de correos
        // Función para cargar historial desde base de datos (SIN localStorage)
        function emailLoadHistory() {
            if (!whspCurrentClientData) {
                console.log('No hay datos del cliente/personal');
                return;
            }

            const historyList = document.getElementById('emailHistoryList');
            historyList.innerHTML = '<div class="text-center"><i class="fas fa-spinner fa-spin"></i> Cargando historial...</div>';

            // Cargar historial desde el servidor
            fetch('/DashboardRerservas/ObtenerHistorialCorreos', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    IdCliente: whspCurrentClientData.idCliente,
                    IdPersonal: whspCurrentClientData.idParaMensajeria
                })
            })
                .then(response => response.json())
                .then(data => {
                    if (data.success && data.correos) {
                        emailRenderHistory(data.correos);
                    } else {
                        historyList.innerHTML = `
                                                <div class="email-history-empty">
                                                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                                                    <p class="text-muted">No hay correos enviados aún</p>
