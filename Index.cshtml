        function whspStartMessagePolling() {
            if (whspPollingActive) return;
            whspCurrentConversationId = `${whspCurrentClientData.idCliente}_${whspCurrentClientData.idParaMensajeria}`;
            whspPollingActive = true;

            whspPollingInterval = setInterval(whspCheckForNewMessages, whspPollingFrequency);
        }

        function whspStopMessagePolling() {
            if (whspPollingInterval) clearInterval(whspPollingInterval);
            whspPollingInterval = null;
            whspPollingActive = false;
            whspCurrentConversationId = null;
        }

        function whspCheckForNewMessages() {
            const currentId = `${whspCurrentClientData.idCliente}_${whspCurrentClientData.idParaMensajeria}`;
            if (currentId !== whspCurrentConversationId) return;

            fetch('/DashboardRerservas/ObtenerConversacionPersonalCliente', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify({
                    idCliente: whspCurrentClientData.idCliente,
                    idPersonal: whspCurrentClientData.idParaMensajeria
                })
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success && data.conversacionExiste && currentId === whspCurrentConversationId) {
                        whspProcessNewMessages(data.mensajes);
                    }
                })
                .catch(e => console.error('Error en polling:', e));
        }




