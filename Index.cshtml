        // Función para manejar la selección de archivos
        // Función para manejar la selección de archivos
        function emailHandleFileSelect(event) {
            console.log('emailHandleFileSelect llamada');

            let files = [];

            // Obtener archivos del evento
            if (event.target && event.target.files) {
                files = Array.from(event.target.files);
                console.log('Archivos desde input:', files.length);
            } else if (event.dataTransfer && event.dataTransfer.files) {
                files = Array.from(event.dataTransfer.files);
                console.log('Archivos desde drag&drop:', files.length);
            }

            if (files.length === 0) {
                console.log('No se encontraron archivos');
                return;
            }

            files.forEach(file => {
                console.log('Procesando archivo:', file.name, 'Tamaño:', file.size);

                if (file.size <= 25 * 1024 * 1024) { // 25MB máximo
                    // Verificar que no esté ya agregado
                    const fileExists = emailAttachedFiles.some(existingFile =>
                        existingFile.name === file.name && existingFile.size === file.size
                    );

                    if (!fileExists) {
                        emailAttachedFiles.push(file);
                        emailShowNotification(`Archivo "${file.name}" agregado correctamente`, 'success');
                        console.log('Archivo agregado:', file.name);
                    } else {
                        emailShowNotification(`El archivo "${file.name}" ya está agregado`, 'warning');
                    }
                } else {
                    emailShowNotification(`El archivo "${file.name}" es demasiado grande (máximo 25MB)`, 'error');
                }
            });

            emailUpdateAttachmentsList();

            // Limpiar input para permitir seleccionar el mismo archivo nuevamente
            if (event.target) {
                event.target.value = '';
            }
        }

        // Función para actualizar la lista de archivos adjuntos
