        // Función para alternar contenido del email en el historial
        function emailToggleContent(emailId) {
            const content = document.getElementById(`content-${emailId}`);
            const toggle = document.getElementById(`toggle-${emailId}`);

            if (content.classList.contains('show')) {
                content.classList.remove('show');
                toggle.classList.remove('expanded');
            } else {
                content.classList.add('show');
                toggle.classList.add('expanded');
            }
        }

        // Función para formatear fecha
        function emailFormatDate(date) {
            const d = new Date(date);
            const now = new Date();
            const diffTime = Math.abs(now - d);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            if (diffDays === 1) {
                return 'Hoy ' + d.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
            } else if (diffDays === 2) {
                return 'Ayer ' + d.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
            } else {
                return d.toLocaleDateString('es-ES') + ' ' + d.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' });
            }
        }

        // Función para buscar en el historial
        function emailSearchHistory() {
            const searchTerm = document.getElementById('emailHistorySearch').value.toLowerCase();
            const historyItems = document.querySelectorAll('.email-history-item');

            historyItems.forEach(item => {
                const to = item.querySelector('.email-history-to').textContent.toLowerCase();
                const subject = item.querySelector('.email-history-subject').textContent.toLowerCase();

                if (to.includes(searchTerm) || subject.includes(searchTerm)) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }

        // Función para editar borrador
        function emailEditDraft(emailId) {
            const draft = emailHistory.find(email => email.id === emailId);
            if (draft) {
                document.getElementById('emailTo').value = draft.to;
                document.getElementById('emailSubject').value = draft.subject;
                document.getElementById('emailEditor').innerHTML = draft.content;
                emailAttachedFiles = [...draft.attachments];
                emailUpdateAttachmentsList();

                // Cambiar a la sección de redactar
                emailShowSection('compose');

                // Eliminar el borrador del historial
                emailDeleteDraft(emailId);

                emailShowNotification('Borrador cargado para edición', 'info');
            }
        }

        // Función para enviar borrador
        function emailSendDraft(emailId) {
            const draftIndex = emailHistory.findIndex(email => email.id === emailId);
            if (draftIndex !== -1) {
                emailHistory[draftIndex].status = 'sent';
                emailHistory[draftIndex].date = new Date();

                try {
                    localStorage.setItem('emailHistory', JSON.stringify(emailHistory));
                } catch (e) {
                    console.log('Error guardando en localStorage');
                }

                emailLoadHistory();
                emailShowNotification('¡Borrador enviado exitosamente!', 'success');
            }
        }

        // Función para eliminar borrador
        function emailDeleteDraft(emailId) {
            if (confirm('¿Está seguro de que desea eliminar este borrador?')) {
                emailHistory = emailHistory.filter(email => email.id !== emailId);

                try {
                    localStorage.setItem('emailHistory', JSON.stringify(emailHistory));
                } catch (e) {
                    console.log('Error guardando en localStorage');
                }

                emailLoadHistory();
                emailShowNotification('Borrador eliminado', 'info');
            }
        }

