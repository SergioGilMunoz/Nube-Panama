        // Función para enviar el correo
        async function emailSendMessage() {
            const to = document.getElementById('emailTo').value.trim();
            const subject = document.getElementById('emailSubject').value.trim();
            const content = document.getElementById('emailEditor').innerHTML.trim();

            // Validaciones
            if (!to) {
                emailShowNotification('Por favor ingrese el destinatario', 'error');
                return;
            }

            if (!emailValidateEmail(to)) {
                emailShowNotification('Por favor ingrese un email válido', 'error');
                return;
            }

            if (!subject) {
                emailShowNotification('Por favor ingrese el asunto', 'error');
                return;
            }

            if (!content || content === '<br>' || content === '') {
                emailShowNotification('Por favor escriba el mensaje', 'error');
                return;
            }

            // Mostrar indicador de envío
            emailShowNotification('Enviando correo...', 'info');

            try {
                // Convertir archivos a Base64
                const archivosBase64 = [];
                if (emailAttachedFiles && emailAttachedFiles.length > 0) {
                    emailShowNotification('Procesando archivos adjuntos...', 'info');

                    for (const file of emailAttachedFiles) {
                        const base64Data = await fileToBase64(file);
                        archivosBase64.push({
                            nombre: file.name,
                            tipo: file.type,
                            tamaño: file.size,
                            datos: base64Data.split(',')[1] // Remover el prefijo data:...;base64,
                        });
                    }
                }

                // Preparar datos como JSON puro
                const emailData = {
                    EmailDestinatario: to,
                    Asunto: subject,
                    Contenido: content,
                    IdPersonal: whspCurrentClientData ? whspCurrentClientData.idParaMensajeria : null,
                    IdCliente: whspCurrentClientData ? whspCurrentClientData.idCliente : null,
                    ArchivosAdjuntos: archivosBase64
                };

                // Realizar petición AJAX con JSON puro
                const response = await fetch('/DashboardRerservas/EnviarCorreoPersonal', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(emailData)
                });

                if (!response.ok) {
                    throw new Error(`Error HTTP: ${response.status}`);
                }

                const data = await response.json();

                if (data.success) {
                    emailShowNotification('¡Correo enviado exitosamente!', 'success');
                    emailClearForm();

                    // Recargar historial automáticamente
                    if (emailCurrentSection === 'history') {
                        emailLoadHistory();
                    }
                } else {
                    emailShowNotification(`Error al enviar: ${data.message}`, 'error');
                }

            } catch (error) {
                console.error('Error en petición AJAX:', error);
                emailShowNotification('Error de conexión al servidor', 'error');
            }
        }

        // Función para convertir archivo a Base64
        function fileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.readAsDataURL(file);
                reader.onload = () => resolve(reader.result);
                reader.onerror = error => reject(error);
            });
        }
       

        // Función para guardar borrador
        function emailSaveDraft() {
            const to = document.getElementById('emailTo').value.trim();
            const subject = document.getElementById('emailSubject').value.trim();
            const content = document.getElementById('emailEditor').innerHTML.trim();

            if (!to && !subject && !content) {
                emailShowNotification('No hay contenido para guardar', 'warning');
                return;
            }

            const draftData = {
                id: Date.now(),
                to: to,
                subject: subject,
                content: content,
                attachments: [...emailAttachedFiles],
                date: new Date(),
                status: 'draft',
                from: whspCurrentClientData ? whspCurrentClientData.personalEmail : 'agencia@email.com'
            };

            // Agregar al historial como borrador
            emailHistory.unshift(draftData);

            try {
                localStorage.setItem('emailHistory', JSON.stringify(emailHistory));
            } catch (e) {
                console.log('LocalStorage no disponible');
            }

            emailShowNotification('Borrador guardado correctamente', 'success');
        }


