        function createPersonalCompleteChart(reconfirmadas, confirmadas, anuladas, cotizaciones, convertidas, ventasReconf, ventasConf, ventasAnu) {
            const ctx = document.getElementById('personalCompleteChart').getContext('2d');

            // Destruir chart anterior si existe
            if (window.personalCompleteChart && typeof window.personalCompleteChart.destroy === 'function') {
                window.personalCompleteChart.destroy();
            }

            // Preparar datos para el chart de pastel
            const labels = [];
            const data = [];
            const backgroundColors = [];
            const borderColors = [];

            // Solo agregar datos que tengan valores > 0
            if (reconfirmadas > 0) {
                labels.push(`Reconfirmadas (${reconfirmadas})`);
                data.push(reconfirmadas);
                backgroundColors.push('rgba(40, 167, 69, 0.8)');
                borderColors.push('rgba(40, 167, 69, 1)');
            }

            if (confirmadas > 0) {
                labels.push(`Confirmadas (${confirmadas})`);
                data.push(confirmadas);
                backgroundColors.push('rgba(255, 193, 7, 0.8)');
                borderColors.push('rgba(255, 193, 7, 1)');
            }

            if (anuladas > 0) {
                labels.push(`Anuladas (${anuladas})`);
                data.push(anuladas);
                backgroundColors.push('rgba(220, 53, 69, 0.8)');
                borderColors.push('rgba(220, 53, 69, 1)');
            }

            if (cotizaciones > 0) {
                labels.push(`Cotizaciones (${cotizaciones})`);
                data.push(cotizaciones);
                backgroundColors.push('rgba(13, 110, 253, 0.8)');
                borderColors.push('rgba(13, 110, 253, 1)');
            }

            if (convertidas > 0) {
                labels.push(`Convertidas (${convertidas})`);
                data.push(convertidas);
                backgroundColors.push('rgba(111, 66, 193, 0.8)');
                borderColors.push('rgba(111, 66, 193, 1)');
            }

            // Si no hay datos, mostrar mensaje
            if (data.length === 0) {
                ctx.font = '16px Arial';
                ctx.textAlign = 'center';
                ctx.fillStyle = '#6c757d';
                ctx.fillText('Sin datos para mostrar', ctx.canvas.width / 2, ctx.canvas.height / 2);
                return;
            }

            window.personalCompleteChart = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: backgroundColors,
                        borderColor: borderColors,
                        borderWidth: 2,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 20,
                                usePointStyle: true,
                                font: {
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            enabled: false // Deshabilitar tooltip ya que los números están visibles
                        },
                        // Plugin para mostrar números en cada segmento
                        datalabels: {
                            display: true,
                            color: 'white',
                            font: {
                                weight: 'bold',
                                size: 14
                            },
                            formatter: function (value, context) {
                                return value; // Mostrar solo la cantidad
                            },
                            anchor: 'center',
                            align: 'center'
                        }
                    },
                    cutout: '40%',
                    // Plugin personalizado para mostrar números en segmentos
                    plugins: [{
                        afterDatasetDraw: function (chart) {
                            const ctx = chart.ctx;
                            const meta = chart.getDatasetMeta(0);

                            meta.data.forEach((arc, index) => {
                                const centerPoint = arc.getCenterPoint();
                                const value = chart.data.datasets[0].data[index];

                                ctx.save();
                                ctx.fillStyle = 'white';
                                ctx.font = 'bold 16px Arial';
                                ctx.textAlign = 'center';
                                ctx.textBaseline = 'middle';

                                // Dibujar el número en el centro del segmento
                                ctx.fillText(value.toString(), centerPoint.x, centerPoint.y);
                                ctx.restore();
                            });
                        },
                        beforeDraw: function (chart) {
                            const width = chart.width;
                            const height = chart.height;
                            const ctx = chart.ctx;

                            ctx.restore();
                            const fontSize = (height / 114).toFixed(2);
                            ctx.font = fontSize + "em Arial";
                            ctx.textBaseline = "middle";
                            ctx.fillStyle = "#000";

                            const total = data.reduce((a, b) => a + b, 0);
                            const text = `Total: ${total}`;
                            const textX = Math.round((width - ctx.measureText(text).width) / 2);
                            const textY = height / 2;

                            ctx.fillText(text, textX, textY);
                            ctx.save();
                        }
                    }]
                }
            });
        }
     





