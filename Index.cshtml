        function loadRealCountriesByRegion(regionId) {
            const region = reservasData.find(r => r.id_region === regionId);
            if (!region) return;

            const countriesSection = document.getElementById('countries-section');
            const countriesList = document.getElementById('countries-list');

            countriesList.innerHTML = region.paises.map(pais => `
                                                                                                            <li>
                                                                                                                <a href="#" class="d-flex py-1 align-items-center country-item"
                                                                                                                   data-country-id="${pais.id_pais}" data-region-id="${regionId}">
                                                                                                                    <div class="flex-grow-1">
                                                                                                                        <h5 class="fs-13 mb-0 listname">${pais.nombre_pais}</h5>
                                                                                                                    </div>
                                                                                                                    <div class="flex-shrink-0 ms-2">
                                                                                                                        <span class="badge bg-light text-muted">${pais.clientes.length}</span>
                                                                                                                    </div>
                                                                                                                </a>
                                                                                                            </li>
                                                                                                        `).join('');

            countriesSection.style.display = 'block';

            // Event listeners para países reales con loading
            document.querySelectorAll('.country-item').forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    document.querySelectorAll('.country-item').forEach(c => c.classList.remove('active'));
                    this.classList.add('active');

                    const countryId = parseInt(this.dataset.countryId);
                    const regionId = parseInt(this.dataset.regionId);
                    const countryName = this.querySelector('.listname').textContent;

                    // Usar la función con loading states
                    loadRealCountryDashboard(regionId, countryId, countryName);
                });
            });
        }

        function loadRealCountryDashboard(regionId, countryId, countryName) {

            document.getElementById('dashboard-loading').style.display = 'block';
            document.getElementById('dashboard-section').style.display = 'none';

            const region = reservasData.find(r => r.id_region === regionId);
            const pais = region.paises.find(p => p.id_pais === countryId);

            if (!pais) return;

            document.getElementById('country-title').textContent = `Dashboard - ${countryName}`;
            document.getElementById('dashboard-section').style.display = 'block';

            document.getElementById('dashboard-loading').style.display = 'none';
            document.getElementById('dashboard-section').style.display = 'block';

            // Calcular estadísticas reales
            calculateRealStats(pais);
            loadRealClientsByCountry(pais, countryName);

            // Cambiar a pestaña dashboard
            document.querySelector('[href="#dashboard-tab"]').click();

            // createClientesReconfirmadasChart(clients);
        }

        function calculateRealStats(pais) {
            let totalReservas = 0, reconfirmadas = 0, confirmadas = 0, anuladas = 0;
            let precioReconf = 0, precioConf = 0, precioAnu = 0;

            pais.clientes.forEach(cliente => {
                cliente.personal.forEach(personal => {
                    if (personal.personal_reservas) {
                        const reservas = personal.personal_reservas.reservas;

                        totalReservas += reservas.reconfirmado.length + reservas.confirmado.length + reservas.anulado.length;
                        reconfirmadas += reservas.reconfirmado.length;
                        confirmadas += reservas.confirmado.length;
                        anuladas += reservas.anulado.length;

                        precioReconf += reservas.reconfirmado.reduce((sum, r) => sum + r.total, 0);
                        precioConf += reservas.confirmado.reduce((sum, r) => sum + r.total, 0);
                        precioAnu += reservas.anulado.reduce((sum, r) => sum + r.total, 0);
                    }
                });
            });

            // Actualizar dashboard
            document.getElementById('total-reservas').textContent = totalReservas;
            document.getElementById('total-reconfirmadas').textContent = reconfirmadas;
            document.getElementById('total-confirmadas').textContent = confirmadas;
            document.getElementById('total-anuladas').textContent = anuladas;
            document.getElementById('precio-reconfirmadas').textContent = `${precioReconf.toLocaleString()}`;
            document.getElementById('precio-confirmadas').textContent = `${precioConf.toLocaleString()}`;
            document.getElementById('precio-anuladas').textContent = `${precioAnu.toLocaleString()}`;
        }


        let whspChartCounter = 0; 

        function loadRealClientsByCountry(pais, countryName) {

            allClientsData = pais.clientes;

            const clients = pais.clientes.map((cliente, index) => {
                let totalReservas = 0, reconfirmadas = 0, cotizaciones = 0, convertidas = 0, ventasTotal = 0;
                let confirmadasCount = 0, anuladasCount = 0;
                let reconfirmadasTotal = 0, confirmadasTotal = 0, anuladasTotal = 0;
                let ventaMesActual = 0, ventaMesAnterior = 0, ventaMesAnteriorAnterior = 0;
                const paquetes = []; let ultimaReservaInfo = null;

                cliente.personal.forEach(personal => {
                    if (personal.personal_reservas) {
                        const reservas = personal.personal_reservas.reservas;
                        totalReservas += reservas.reconfirmado.length + reservas.confirmado.length + reservas.anulado.length;
                        reconfirmadas += reservas.reconfirmado.length;
                        confirmadasCount += reservas.confirmado.length;
                        anuladasCount += reservas.anulado.length;

                        reconfirmadasTotal += reservas.reconfirmado.reduce((sum, r) => sum + r.total, 0);
                        confirmadasTotal += reservas.confirmado.reduce((sum, r) => sum + r.total, 0);
                        anuladasTotal += reservas.anulado.reduce((sum, r) => sum + r.total, 0);
                        ventasTotal += reservas.reconfirmado.reduce((sum, r) => sum + r.total, 0);

                        // Sumar ventas del mes actual y anterior
                        ventaMesActual += reservas.reconfirmado.reduce((sum, r) => sum + (r.venta_mes_actual || 0), 0);
                        ventaMesAnterior += reservas.reconfirmado.reduce((sum, r) => sum + (r.venta_mes_anterior || 0), 0); 
                        ventaMesAnterior += reservas.reconfirmado.reduce((sum, r) => sum + (r.venta_mes_anterior_anterior || 0), 0); 

                        convertidas += [...reservas.reconfirmado, ...reservas.confirmado, ...reservas.anulado]
                            .filter(r => r.id_cotizacion_origen).length;


                        reservas.reconfirmado.forEach(reserva => {
                            let fechaReserva = null;
                            if (reserva.fecha_reserva) {
                                const timestampMatch = reserva.fecha_reserva.toString().match(/\/Date\((\d+)\)\//);
                                if (timestampMatch) {
                                    fechaReserva = new Date(parseInt(timestampMatch[1]));
                                }
                            }

                            if (fechaReserva && (!ultimaReservaInfo || fechaReserva > ultimaReservaInfo.fecha)) {
                                ultimaReservaInfo = {
                                    fecha: fechaReserva,
                                    nombre: reserva.nombre_paquete || reserva.nombre_reserva || 'Sin nombre'
                                };
                            }
                        });




                    }

                    if (personal.personal_cotizaciones) {
                        cotizaciones += personal.personal_cotizaciones.cotizaciones.length;
                    }






                });

                // === Acumular paquetes de cada personal ===
                cliente.personal.forEach(personal => {
                    if (personal.personal_reservas?.reservas?.reconfirmado) {
                        personal.personal_reservas.reservas.reconfirmado.forEach(reserva => {
                            if (reserva.nombre_paquete) {
                                paquetes.push(reserva.nombre_paquete);
                            }
                        });
                    }
                });


                // Contar y ordenar
                const conteo = {};
                paquetes.forEach(nombre => {
                    conteo[nombre] = (conteo[nombre] || 0) + 1;
                });

                topPaquetes = Object.entries(conteo)
                    .map(([nombre, cantidad]) => ({ nombre, cantidad }))
                    .sort((a, b) => b.cantidad - a.cantidad)
                    .slice(0, 10);
                // =============================================


                // Calcular porcentajes para el chart
                const totalChart = reconfirmadas + confirmadasCount + anuladasCount;
                const reconfirmadasPct = totalChart > 0 ? ((reconfirmadas / totalChart) * 100).toFixed(1) : 0;
                const confirmadasPct = totalChart > 0 ? ((confirmadasCount / totalChart) * 100).toFixed(1) : 0;
                const anuladasPct = totalChart > 0 ? ((anuladasCount / totalChart) * 100).toFixed(1) : 0;

                return {
                    ranking: index + 1,
                    nombre: cliente.nombre_cliente,
                    email: cliente.correo_electronico,
                    telefono: cliente.telefono,
                    telefono_ws: cliente.telefono_ws,
                    totalReservas,
                    reconfirmadas,
                    confirmadas: confirmadasCount,
                    anuladas: anuladasCount,
                    cotizaciones,
                    convertidas,
                    ventasTotal,
                    ventaMesActual: Math.round(ventaMesActual),
                    ventaMesAnterior: Math.round(ventaMesAnterior),
                    ventaMesAnteriorAnterior: Math.round(ventaMesAnteriorAnterior),
                    reconfirmadasTotal,
                    confirmadasTotal,
                    anuladasTotal,
                    reconfirmadasPct,
                    confirmadasPct,
                    anuladasPct,
                    clienteData: cliente,
                    topPaquetes,
                    ultimaReservaInfo,
                };
            });

            // Ordenar por ventas totales para ranking
            clients.sort((a, b) => b.ventasTotal - a.ventasTotal);
            clients.forEach((client, index) => {
                client.ranking = index + 1;
            });

            // Actualizar tabla
            const tbody = document.getElementById('clients-table-body');
            tbody.innerHTML = clients.map(client => `
