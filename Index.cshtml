        function updateSalesRangeSlider(clients) {
            if (!clients || clients.length === 0) return;

            // El cliente #1 del ranking es el primero del array (ya está ordenado por ventas)
            const topClient = clients[0];
            let maxSales = 0;

            if (topClient && topClient.ventasTotal > 0) {
                // Tomar la venta del cliente #1 del ranking + 1000
                maxSales = topClient.ventasTotal + 1000;
            } else {
                // Si el cliente #1 no tiene ventas, usar rango por defecto
                maxSales = 10000;
            }

            console.log(`Cliente #1: ${topClient?.nombre || 'N/A'}, Ventas: ${topClient?.ventasTotal || 0}, Nuevo máximo: ${maxSales}`);

            // Destruir slider existente y crear uno nuevo
            const rangeSlider = document.getElementById('sales-price-range');
            if (rangeSlider) {
                // Limpiar el slider anterior
                if (salesRangeSlider) {
                    salesRangeSlider.destroy();
                }

                // Crear nuevo slider con el rango correcto
                salesRangeSlider = noUiSlider.create(rangeSlider, {
                    start: [0, maxSales],
                    connect: true,
                    range: {
                        'min': 0,
                        'max': maxSales
                    },
                    format: {
                        to: function (value) {
                            return Math.round(value);
                        },
                        from: function (value) {
                            return Number(value);
                        }
                    }
                });

                // Agregar event listener al nuevo slider
                salesRangeSlider.on('update', function (values) {
                    document.getElementById('minSales').value = values[0];
                    document.getElementById('maxSales').value = values[1];
                    filterClientsBySalesRange(values[0], values[1]);
                });
            }

            // Actualizar inputs
            document.getElementById('minSales').value = 0;
            document.getElementById('maxSales').value = maxSales;
        }



