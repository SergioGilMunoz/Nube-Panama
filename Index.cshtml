            //                                                    `).join('');






            document.getElementById('paquetes-vendidos-window').innerHTML = paquetesHtml ||
                '<div class="text-center text-muted py-3"><i class="fas fa-box fa-2x mb-2"></i><br>No hay paquetes vendidos</div>';


            // Convertir /Date(1736448540000)/ a objeto Date
            function parseJsonNetDate(dateString) {
                if (!dateString) return null;
                const match = dateString.match(/\/Date\((\d+)\)\//);
                return match ? new Date(parseInt(match[1])) : null;
            }

         

            function formatearFecha(date) {
                return date.toLocaleDateString('es-ES', {
                    day: '2-digit',
                    month: '2-digit',
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            }

            // Validar que haya datos
            if (reconfirmadas && reconfirmadas.length > 0) {
                // Encontrar la reserva más reciente por fecha_reserva
                const ultimaReserva = reconfirmadas.reduce((ultima, actual) => {
                    const fechaUltima = parseJsonNetDate(ultima.fecha_reserva);
                    const fechaActual = parseJsonNetDate(actual.fecha_reserva);
                    return fechaActual > fechaUltima ? actual : ultima;
                });

                // Obtener la fecha
                const fecha = parseJsonNetDate(ultimaReserva.fecha_reserva);

                // Obtener nombre: primero intentar nombre_paquete, si no, usar nombre_reserva
                const nombreMostrar = ultimaReserva.nombre_paquete
                    ? ultimaReserva.nombre_paquete
