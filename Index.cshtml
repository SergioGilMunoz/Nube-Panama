        // ========================
        // verificar
        // ========================

        function whspFixModalEventConflict() {
            const input = document.getElementById('whspMessageInput');
            const windowContainer = document.getElementById('whspWindowContainer');

            if (input && windowContainer) {
                console.log('🔧 Solucionando conflicto de eventos entre modales...');

                // 1. Encontrar el modal principal y detener su captura de eventos
                const mainModal = document.querySelector('.modal.show, [data-bs-backdrop="static"], .modal-dialog').closest('.modal');
                const modalBackdrop = document.querySelector('.modal-backdrop');

                if (mainModal) {
                    console.log('🎯 Modal principal encontrado:', mainModal);

                    // Temporalmente desactivar la captura de eventos del modal principal
                    const originalKeydownHandler = mainModal.onkeydown;
                    const originalKeypressHandler = mainModal.onkeypress;

                    mainModal.onkeydown = null;
                    mainModal.onkeypress = null;

                    // Detener la propagación de eventos desde el modal
                    mainModal.addEventListener('keydown', function (e) {
                        if (e.target.closest('#whspWindowContainer')) {
                            return; // No interceptar si viene de la ventana drag&drop
                        }
                    }, true);
                }

                // 2. Asegurar que la ventana drag&drop esté por encima
                windowContainer.style.zIndex = '1050';
                input.style.zIndex = '1050';

                // 3. Permitir que el input capture eventos directamente
                input.addEventListener('keydown', function (e) {
                    e.stopImmediatePropagation(); // Detener TODOS los otros handlers

                    // Manejar eventos específicos manualmente
                    if (e.key === 'Enter' && typeof whspHandleKeyDown === 'function') {
                        whspHandleKeyDown(e);
                    }
                }, true); // true = capture phase, se ejecuta antes que otros

                input.addEventListener('keypress', function (e) {
                    e.stopImmediatePropagation();

                    if (typeof whspHandleEnterKey === 'function') {
                        whspHandleEnterKey(e);
                    }
                }, true);

                // 4. Hacer que el input sea totalmente independiente
                input.addEventListener('input', function (e) {
                    console.log('✅ Escribiendo (independiente del modal):', e.target.value);
                    e.stopPropagation();
                });

                // 5. Focus inmediato y forzado
                setTimeout(() => {
                    input.focus();
                    console.log('✅ Input enfocado independientemente del modal');
                }, 50);

                console.log('✅ Conflicto de modales solucionado');
            }
        }


