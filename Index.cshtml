                anuladas = reservas.anulado;

                // Contar cotizaciones convertidas
                const todasReservas = [...reconfirmadas, ...confirmadas, ...anuladas];
                cotizacionesConvertidas = todasReservas.filter(r => r.id_cotizacion_origen).length;
            }

            // Procesar datos de cotizaciones (si existen)
