            fetch('/DashboardRerservas/ObtenerConversacionPersonalCliente', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify({ idCliente, idPersonal })
            })
                .then(r => r.json())
                .then(data => {
                    //if (!data.success || !data.conversacionExiste || !Array.isArray(data.mensajes)) {
                    if (!data.success) {
                        whspMostrarErrorCarga();
                        return;
                    }

                    whspLimpiarAreaMensajes();

                    data.mensajes.forEach(m => {
                        //  const fecha = whspFormatearFechaRecibida(m.datetime);
                        const fecha = m.datetime;

                        // ✅ Verificar si es un archivo con URL pública
                        if (m.rutaImagenEnviada && m.rutaImagenEnviada.trim() !== '') {
                            const file = {
                                name: m.nombreArchivo || 'archivo',
                                type: m.tipoArchivo || 'application/octet-stream',
                                size: m.tamanoArchivo || 0
                            };

                            // ✅ Asegurar que es imagen aunque sea .jfif
                            if (file.name.toLowerCase().endsWith('.jfif') && !file.type.startsWith('image/')) {
                                file.type = 'image/jpeg';
                            }

                            const fileMessage = whspCreateFileMessage(file, m.rutaImagenEnviada);

                            if (m.from_Id === "1") {
                                // whspAddMyMessage(fileMessage, true);
                                whspAddMyMessageLoadImage(fileMessage, fecha, true);
                            } else {
                                whspAddClientMessage(fileMessage);
                            }
                        }
                        // ✅ Mensaje de texto
                        else {
                            whspAgregarMensajeCargado(m.mensaje, fecha, m.from_Id === "1");
                        }
                    });

                    whspLastMessageCount = data.mensajes.length;
                    whspMessageCount = data.mensajes.filter(m => m.from_Id === "1").length;
                    whspClientResponses = data.mensajes.filter(m => m.from_Id === "2").length;
                    whspUpdateStats();
                    whspScrollToBottom();
                })
                .catch(err => {
                    console.error('Error cargando conversación:', err);
                    whspMostrarErrorCarga();
                });
        }


