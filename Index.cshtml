        // Función para filtrar clientes por rango de ventas// Función para filtrar clientes por rango de ventas
        function filterClientsBySalesRange(minSales, maxSales) {
            console.log(`Filtrar clientes con ventas entre ${minSales} y ${maxSales}`);

            if (allClientsData.length === 0) return;

            const tableBody = document.getElementById('clients-table-body');
            if (!tableBody) return;

            const rows = tableBody.querySelectorAll('tr');

            let visibleCount = 0;

            rows.forEach(row => {
                const salesCell = row.querySelector('td:nth-last-child(2) strong');
                if (salesCell) {
                    const salesAmount = parseFloat(salesCell.textContent.replace(/,/g, ''));

                    if (salesAmount >= minSales && salesAmount <= maxSales) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                }
            });

            // Actualizar contador solo si los elementos existen
            const clientsCountElement = document.getElementById('clients-count-number');
            const dashboardCountElement = document.getElementById('dashboard-count-number');

            if (clientsCountElement) {
                clientsCountElement.textContent = visibleCount;
            }
            if (dashboardCountElement) {
                dashboardCountElement.textContent = visibleCount;
            }
        }


