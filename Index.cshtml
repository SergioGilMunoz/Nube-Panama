        function emailInitializeDragDrop() {
            const uploadArea = document.getElementById('emailFileUploadArea');
            const fileInput = document.getElementById('emailFileInput');

            if (!uploadArea || !fileInput) {
                console.log('Elementos de upload no encontrados');
                return;
            }

            // Limpiar event listeners previos
            uploadArea.replaceWith(uploadArea.cloneNode(true));
            const newUploadArea = document.getElementById('emailFileUploadArea');

            // Click para seleccionar archivos
            newUploadArea.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                console.log('Click en área de upload');
                fileInput.click();
            });

            // Prevenir comportamiento por defecto del navegador
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                newUploadArea.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                });

                // También prevenir en el documento
                document.addEventListener(eventName, (e) => {
                    e.preventDefault();
                    e.stopPropagation();
                });
            });

            // Efectos visuales durante el drag
            newUploadArea.addEventListener('dragenter', (e) => {
                newUploadArea.classList.add('drag-over');
                console.log('Drag enter');
            });

            newUploadArea.addEventListener('dragover', (e) => {
                newUploadArea.classList.add('drag-over');
            });

            newUploadArea.addEventListener('dragleave', (e) => {
                // Solo remover si realmente salimos del área
                if (!newUploadArea.contains(e.relatedTarget)) {
                    newUploadArea.classList.remove('drag-over');
                }
            });

            // Manejar archivos soltados
            newUploadArea.addEventListener('drop', (e) => {
                console.log('Drop event triggered');
                newUploadArea.classList.remove('drag-over');

                const files = e.dataTransfer.files;
                if (files.length > 0) {
                    console.log('Archivos detectados:', files.length);
                    emailHandleFileSelect({ dataTransfer: { files } });
                }
            });

            // Event listener para el input de archivo
            fileInput.addEventListener('change', (e) => {
                console.log('File input changed:', e.target.files.length);
                emailHandleFileSelect(e);
            });

            console.log('Drag & Drop inicializado correctamente');
        }

        // Inicializar cuando se abre el modal de mensajería
        function emailInitialize() {
            console.log('Inicializando sistema de correos...');

            // Configurar drag & drop
            setTimeout(() => {
                emailInitializeDragDrop();
            }, 100);

            // Llenar información del personal si está disponible
            if (whspCurrentClientData) {
                document.getElementById('emailPersonalName').textContent = whspCurrentClientData.personalNombre || 'N/A';
                document.getElementById('emailPersonalEmail').textContent = whspCurrentClientData.personalEmail || 'N/A';
                document.getElementById('emailPersonalPhone').textContent = whspCurrentClientData.personalTelefono || 'N/A';

                // AUTO-LLENAR el campo "Para" con el email del personal
                const emailInput = document.getElementById('emailTo');
                if (emailInput && whspCurrentClientData.personalEmail && whspCurrentClientData.personalEmail !== 'N/A') {
                    emailInput.value = whspCurrentClientData.personalEmail;
                }
            }

            // Cargar historial al inicializar
            try {
                const savedHistory = localStorage.getItem('emailHistory');
                if (savedHistory) {
                    emailHistory = JSON.parse(savedHistory);
                }
            } catch (e) {
                console.log('Error cargando historial inicial');
            }

            // Limpiar solo los campos que no queremos pre-llenar
            document.getElementById('emailSubject').value = '';
            document.getElementById('emailEditor').innerHTML = '';
            emailAttachedFiles = [];
            emailUpdateAttachmentsList();
            document.getElementById('emailFileInput').value = '';

            console.log('Sistema de correos inicializado');
        }


        // Función AJAX para enviar correo electrónico
        function emailSendAjax(emailData, attachedFiles) {
            const formData = new FormData();

            // Agregar datos del correo
            formData.append('to', emailData.to);
            formData.append('subject', emailData.subject);
            formData.append('content', emailData.content);
            formData.append('from', emailData.from);

            // Agregar archivos adjuntos
            if (attachedFiles && attachedFiles.length > 0) {
                attachedFiles.forEach((file, index) => {
                    formData.append(`attachment_${index}`, file);
                });
                formData.append('attachmentCount', attachedFiles.length);
            }

            // Datos adicionales del cliente/personal
            if (whspCurrentClientData) {
                formData.append('clientId', whspCurrentClientData.idCliente);
                formData.append('personalId', whspCurrentClientData.idParaMensajeria);
                formData.append('personalNombre', whspCurrentClientData.personalNombre);
            }

            return new Promise((resolve, reject) => {
                const xhr = new XMLHttpRequest();

                xhr.open('POST', '/DashboardRerservas/EnviarCorreoPersonal', true);

                xhr.onload = function () {
                    if (xhr.status >= 200 && xhr.status < 300) {
                        try {
                            const response = JSON.parse(xhr.responseText);
                            resolve(response);
                        } catch (e) {
                            resolve({ success: true, message: 'Correo enviado exitosamente' });
                        }
                    } else {
                        reject({
                            status: xhr.status,
                            message: xhr.responseText || 'Error al enviar el correo'
                        });
                    }
                };

                xhr.onerror = function () {
                    reject({
                        status: 0,
                        message: 'Error de conexión al servidor'
                    });
                };

                xhr.upload.onprogress = function (e) {
                    if (e.lengthComputable) {
                        const percentComplete = (e.loaded / e.total) * 100;
                        console.log('Progreso de envío:', percentComplete.toFixed(2) + '%');
                    }
                };

                xhr.send(formData);
            });
        }



    </script>
}
