        // ✅ Función corregida: Procesar nuevos mensajes
        function whspProcessNewMessages(mensajes) {
            if (!mensajes || mensajes.length === 0) return;

            const currentId = `${whspCurrentClientData.idCliente}_${whspCurrentClientData.idParaMensajeria}`;
            if (currentId !== whspCurrentConversationId) return;

            if (mensajes.length > whspLastMessageCount) {
                const nuevos = mensajes.slice(whspLastMessageCount);
                let nuevosRecibidos = 0;

                nuevos.forEach(m => {
                    // ✅ Comparación flexible para from_Id
                    if (m.from_Id == "2") {
                        const fecha = whspFormatearFechaRecibida(m.datetime);
                        console.log('📩 Mensaje nuevo del cliente:', m.mensaje, 'a las', fecha);
                        whspAgregarNuevoMensajeCliente(m.mensaje, fecha);
                        nuevosRecibidos++;
                    }
                });

                if (nuevosRecibidos > 0) {
                    whspClientResponses += nuevosRecibidos;
                    whspUpdateStats();
                    whspLastMessageCount = mensajes.length;

                    // ✅ Notificación si no está en foco
                    if (!document.hasFocus()) {
                        whspShowNotification(
                            `Nuevo mensaje de ${whspCurrentClientData.personalNombre}`,
                            nuevos[0].mensaje.substring(0, 50) + '...'
                        );
                    }
                }
            }
        }



        // ========================
        // FORMATO DE FECHA
        // ========================
        function whspFormatearFechaRecibida(fechaServidor) {
            try {
                let fecha;
                if (typeof fechaServidor === 'string') {
                    if (fechaServidor.includes('/Date(')) {
                        const timestamp = parseInt(fechaServidor.match(/\d+/)[0]);
                        fecha = new Date(timestamp);
                    } else {
                        fecha = new Date(fechaServidor);
                    }
                } else {
                    fecha = new Date(fechaServidor);
                }
                return fecha.toLocaleString('es-ES', {
                    day: '2-digit', month: 'short', year: '2-digit', hour: '2-digit', minute: '2-digit'
                });
            } catch (e) {
                return fechaServidor;
            }
        }

