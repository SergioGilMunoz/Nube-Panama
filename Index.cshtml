            const currentTime = new Date().toLocaleString('es-ES', {
                day: '2-digit', month: 'short', year: '2-digit', hour: '2-digit', minute: '2-digit'
            });

            const chatMessageData = {
                from_Id: "1", to_Id: "2", mensaje: message, datetime: currentTime
            };

            let telefono = document.getElementById("whspClientPhone").value;

            const payload = {
                idCliente: whspCurrentClientData.idCliente,
                IdPersonal: whspCurrentClientData.idParaMensajeria,
                Telefono: telefono ,
                nombrePersonal: whspCurrentClientData.personalNombre,
                ChatMessageData: chatMessageData
            };

            fetch('/DashboardRerservas/EnviarMensajePersonalCliente', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify(payload)
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        whspAddMyMessage(message, false);
                        input.value = '';
                        input.style.height = 'auto';
                        whspMessageCount++;
                        whspUpdateStats();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
