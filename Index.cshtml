                totalCotizaciones = personalData.personal_cotizaciones.cotizaciones.length;
            }



            // verifica aqui para el ultimo paquete vendido y la fecha reconfirmada

            // Paquetes más vendidos
            const paquetesMap = new Map();
            reconfirmadas.forEach(reserva => {
                const paquete = reserva.nombre_paquete || 'Reservas varias(no paquetes)';
                if (paquetesMap.has(paquete)) {
                    paquetesMap.set(paquete, paquetesMap.get(paquete) + 1);
                } else {
                    paquetesMap.set(paquete, 1);
                }
            });

            const paquetesArray = Array.from(paquetesMap.entries()).sort((a, b) => b[1] - a[1]);


            // Primero encontrar el último paquete comprado
            let ultimoPaqueteNombre = null;
            if (reconfirmadas && reconfirmadas.length > 0) {
                const ultimaReserva = reconfirmadas.reduce((ultima, actual) => {
                    const fechaUltima = parseJsonNetDate(ultima.fecha_reserva);
                    const fechaActual = parseJsonNetDate(actual.fecha_reserva);
                    return fechaActual > fechaUltima ? actual : ultima;
                });
                ultimoPaqueteNombre = ultimaReserva.nombre_paquete || 'Reservas varias(no paquetes)';
            }

            const paquetesHtml = paquetesArray.slice(0, 8).map(([paquete, cantidad]) => {
                const esUltimoPaquete = paquete === ultimoPaqueteNombre;
                return `
        <div class="d-flex justify-content-between align-items-center py-1 border-bottom ${esUltimoPaquete ? 'bg-warning bg-opacity-25' : ''}">
