                                                                                ${client.ultimaReservaInfo ? `<p class="text-info mb-0 small" title="${client.ultimaReservaInfo.nombre}"><i class="fas fa-calendar me-1"></i> ${client.ultimaReservaInfo.fecha.toLocaleDateString('es-ES')} - ${client.ultimaReservaInfo.nombre.length > 30 ? client.ultimaReservaInfo.nombre.substring(0, 30) + '...' : client.ultimaReservaInfo.nombre}</p>` : '<p class="text-muted mb-0 small"><span class="badge bg-secondary bg-opacity-50 small">Sin reservas</span></p>'}
                                                                               
                                                                                <button class="btn btn-sm btn-outline-info mt-0"
        onclick="mostrarTopPaquetesModal('${client.nombre}', '${encodeURIComponent(JSON.stringify(client.topPaquetes))}')">
    Top 10 Paquetes
</button>
                                                                                
                                                                                </div>
                                                                            </td>

                                                                            <td>
                                                                                <div class="chart-container" data-bs-toggle="tooltip" data-bs-html="true"
                                                                                     title="
                                                                                            📈 Reconfirmadas: ${client.reconfirmadas} ($${client.reconfirmadasTotal.toLocaleString()})
                                                                                            ⏳ Confirmadas: ${client.confirmadas} ($${client.confirmadasTotal.toLocaleString()})
                                                                                            ❌ Anuladas: ${client.anuladas} ($${client.anuladasTotal.toLocaleString()})
                                                                                            📋 Cotizaciones: ${client.cotizaciones}
                                                                                            🔄 Convertidas: ${client.convertidas}">
                                                                                    <div class="mini-chart d-flex" style="height: 30px; border-radius: 15px; overflow: hidden; border: 1px solid #dee2e6;">
                                                                                        <div class="bg-success" style="width: ${client.reconfirmadasPct}%; min-width: ${client.reconfirmadas > 0 ? '8px' : '0'};" title="Reconfirmadas"></div>
                                                                                        <div class="bg-warning" style="width: ${client.confirmadasPct}%; min-width: ${client.confirmadas > 0 ? '8px' : '0'};" title="Confirmadas"></div>
                                                                                        <div class="bg-danger" style="width: ${client.anuladasPct}%; min-width: ${client.anuladas > 0 ? '8px' : '0'};" title="Anuladas"></div>
                                                                                    </div>
                                                                                    <div class="d-flex justify-content-between mt-1">
                                                                                        <small class="text-success">📈 ${client.reconfirmadas}</small>
                                                                                        <small class="text-warning">⏳ ${client.confirmadas}</small>
                                                                                        <small class="text-danger">❌ ${client.anuladas}</small>
                                                                                        <small class="text-info">📋 ${client.cotizaciones}</small>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                            <td><span class="badge bg-dark">${client.clienteData.personal.length}</span></td>
                                                                           
                                                                            <td>
                                                                                    <div class="chart-container" style="width: 200px; height: 80px; margin: 0 auto;">
                                                                                      <canvas class="whsp-bar-chart"
                                                                                                width="200"
                                                                                                height="80"
                                                                                                data-actual="${client.ventaMesActual}"
                                                                                                data-anterior="${client.ventaMesAnterior}"
                                                                                                data-anterior-anterior="${client.ventaMesAnteriorAnterior}"
                                                                                                data-mes-actual="${new Date().getMonth()}"
                                                                                                data-mes-anterior="${new Date(new Date().getFullYear(), new Date().getMonth() - 1).getMonth()}"
                                                                                                data-mes-anterior-anterior="${new Date(new Date().getFullYear(), new Date().getMonth() - 2).getMonth()}">
                                                                                        </canvas>
                                                                                    </div>
                                                                                </td>


                                                                            <td><strong>$${client.ventasTotal.toLocaleString()}</strong></td>
                                                                            <td>
                                                                                <button class="btn btn-sm btn-outline-primary" onclick="showRealPersonalModal('${client.nombre}', ${JSON.stringify(client.clienteData).replace(/"/g, '&quot;')})">
                                                                                    <i class="fas fa-users"></i> Ver Personal
                                                                                </button>
                                                                            </td>
                                                                                    </tr>
                                                                                                        `).join('');

           
        
            // Inicializar todos los gráficos horizontales
            document.querySelectorAll('.whsp-bar-chart').forEach(canvas => {
                const actual = parseFloat(canvas.dataset.actual) || 0;
