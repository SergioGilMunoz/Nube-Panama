@section scripts{
    <!-- nouisliderribute js -->
    <script src="~/assets/libs/nouislider/nouislider.min.js"></script>
    <script src="~/assets/libs/wnumb/wNumb.min.js"></script>

    <!-- gridjs js -->
    <script src="~/assets/libs/gridjs/gridjs.umd.js"></script>
    <script src="https://unpkg.com/gridjs/plugins/selection/dist/selection.umd.js"></script>
    <!-- ecommerce product list -->
    @*<script src="~/assets/js/pages/ecommerce-product-list.init.js"></script>*@

    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <!-- App js -->
    <script src="~/assets/js/app.js"></script>

    @*<script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js"></script>*@
    @*<script src="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.min.js" type="module"></script>
        <script src="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.esm.min.js" type="module"></script>*@



    <script>
        // Variables globales
        let reservasData = [];
        let currentCountryData = [];
        let salesRangeSlider;
        // Variable global para almacenar todos los clientes
        let allClientsData = [];


        // Inicializar slider de rango de ventas solo la primera vez
        function initSalesRangeSlider() {
            const rangeSlider = document.getElementById('sales-price-range');
            if (rangeSlider && !salesRangeSlider) {
                salesRangeSlider = noUiSlider.create(rangeSlider, {
                    start: [0, 500000],
                    connect: true,
                    range: {
                        'min': 0,
                        'max': 500000
                    },
                    format: {
                        to: function (value) {
                            return Math.round(value);
                        },
                        from: function (value) {
                            return Number(value);
                        }
                    }
                });

                salesRangeSlider.on('update', function (values) {
                    document.getElementById('minSales').value = values[0];
                    document.getElementById('maxSales').value = values[1];
                    filterClientsBySalesRange(values[0], values[1]);
                });
            }
        }


        // Función para actualizar contadores con animación
        function updateCounters(count) {
            document.getElementById('dashboard-count-number').textContent = count;
            document.getElementById('clients-count-number').textContent = count;
        }





        // Limpiar todos los filtros con reset de loading
        document.getElementById('clearall').addEventListener('click', function (e) {
            e.preventDefault();

            // Limpiar selecciones
            document.querySelectorAll('.form-check-input').forEach(input => {
                input.checked = false;
            });

            // Resetear slider
            if (salesRangeSlider) {
                salesRangeSlider.set([0, 10000]);
            }

            // Ocultar secciones
            document.getElementById('countries-section').style.display = 'none';
            document.getElementById('dashboard-section').style.display = 'none';

            // Resetear estados de carga
            hideLoadingState();

            // Mostrar estado inicial
            document.getElementById('dashboard-content').innerHTML = `
                                                                                                            <div class="py-4 text-center">
                                                                                                                <i class="fas fa-globe fa-4x text-muted mb-3"></i>
                                                                                                                <h5 class="mt-4">Selecciona un país para ver el dashboard</h5>
                                                                                                                <p class="text-muted">Usa el panel de filtros para seleccionar una región y país</p>
                                                                                                            </div>
                                                                                                        `;

            // Limpiar tablas
            document.getElementById('clients-table-body').innerHTML = '';
            document.getElementById('country-title').textContent = 'Selecciona un país';

            // Resetear contadores
            updateCounters(0);

            // Remover selecciones activas
            document.querySelectorAll('.country-item').forEach(item => {
                item.classList.remove('active');
            });
        });





        // Funciones para integrar con el controlador ASP.NET MVC

        // Función para llamar al controlador y cargar datos reales
        async function loadRealData() {
            document.getElementById('dashboard-loading').style.display = 'block';
            document.getElementById('dashboard-section').style.display = 'none';

            try {
                const response = await fetch('/DashboardRerservas/cargarDataReservas', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({})
                });

                const result = await response.json();

                if (result.success) {
                    reservasData = result.data;
                    processReservasData();

                    document.getElementById('dashboard-loading').style.display = 'none';

                } else {
                    document.getElementById('dashboard-loading').style.display = 'none';

                    console.error('Error cargando datos:', result.errorMessage);
                    alert('Error al cargar los datos: ' + result.errorMessage);
                }
            } catch (error) {
                document.getElementById('dashboard-loading').style.display = 'none';
                console.error('Error en la petición:', error);
                alert('Error de conexión al servidor');
            }
        }

        // Procesar datos del JSON estructurado
        function processReservasData() {
            if (!reservasData || reservasData.length === 0) return;

            // Cargar regiones reales
            loadRealRegions();
        }

        function loadRealRegions() {
            const regionsList = document.getElementById('regions-list');
            const regionsMap = new Map();

            // Procesar regiones del JSON
            reservasData.forEach(region => {
                regionsMap.set(region.id_region, {
                    id: region.id_region,
                    name: region.nombre_region,
                    count: region.paises.length
                });
            });

            const regions = Array.from(regionsMap.values());

            regionsList.innerHTML = regions.map(region => `
                                                                                                            <li>
                                                                                                                <a href="#" class="d-flex py-1 align-items-center region-item" data-region-id="${region.id}">
                                                                                                                    <div class="flex-grow-1">
                                                                                                                        <h5 class="fs-13 mb-0 listname">${region.name}</h5>
                                                                                                                    </div>
                                                                                                                    <div class="flex-shrink-0 ms-2">
                                                                                                                        <span class="badge bg-light text-muted">${region.count}</span>
                                                                                                                    </div>
                                                                                                                </a>
                                                                                                            </li>
                                                                                                        `).join('');

            // Agregar event listeners reales
            document.querySelectorAll('.region-item').forEach(item => {
                item.addEventListener('click', function (e) {
                    e.preventDefault();
                    const regionId = parseInt(this.dataset.regionId);
                    loadRealCountriesByRegion(regionId);
                });
