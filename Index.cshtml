@{
    ViewBag.Title = "Products";
    ViewBag.pTitle = "Products";
    ViewBag.pageTitle = "Ecommerce";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section styles{
    <!-- nouisliderribute css -->
    <link rel="stylesheet" href="~/assets/libs/nouislider/nouislider.min.css">

    <!-- gridjs css -->
    <link rel="stylesheet" href="~/assets/libs/gridjs/theme/mermaid.min.css">

    <!-- Font Awesome (solo sólidos - más ligero) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/solid.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/brands.min.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    @*<link href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css" rel="stylesheet">*@
    @*<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/default-skin/default-skin.css">*@

    <!-- CSS de PhotoSwipe -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.4/dist/photoswipe.css">

    <script type="module">
        import PhotoSwipeLightbox from 'https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe-lightbox.esm.js';

        const lightbox = new PhotoSwipeLightbox({
            gallery: '#whspMessagesArea',
            children: 'a[data-pswp-src]',
            pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.esm.js')
        });

        lightbox.init();

        // Opcional: exponer al window si necesitas reiniciarlo
        window.pswpLightbox = lightbox;
    </script>

}


<div class="row">
    <!-- Panel de Filtros -->
    <div class="col-xl-3 col-lg-4">
        <div class="card">
            <div class="card-header">
                <div class="d-flex mb-3">
                    <div class="flex-grow-1">
                        <h5 class="fs-16">Filtros</h5>
                    </div>
                    <div class="flex-shrink-0 d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-primary" id="reload-data">
                            <i class="fas fa-sync-alt"></i> Cargar Data
                        </button>
                        <a href="#" class="text-decoration-underline align-self-center" id="clearall">Limpiar Todo</a>
                    </div>
                </div>

                <div class="filter-choices-input">
                    <input class="form-control" type="text" id="filter-search-input" placeholder="Buscar clientes..." />
                </div>
            </div>

            <div class="accordion accordion-flush filter-accordion">
                <!-- Filtro de Regiones -->
                <div class="card-body border-bottom">
                    <div>
                        <p class="text-muted text-uppercase fs-12 fw-medium mb-2">Regiones</p>
                        <ul class="list-unstyled mb-0 filter-list" id="regions-list">
                            <!-- Se cargará dinámicamente -->
                        </ul>
                    </div>
                </div>

                <!-- Filtro de Países -->
                <div class="card-body border-bottom" id="countries-section" style="display: none;">
                    <div>
                        <p class="text-muted text-uppercase fs-12 fw-medium mb-2">Países</p>
                        <ul class="list-unstyled mb-0 filter-list" id="countries-list">
                            <!-- Se cargará dinámicamente -->
                        </ul>
                    </div>
                </div>

                <!-- Filtro de Rango de Ventas -->
                <div class="card-body border-bottom">
                    <p class="text-muted text-uppercase fs-12 fw-medium mb-4">Rango de Ventas</p>
                    <div id="sales-price-range"></div>
                    <div class="formCost d-flex gap-2 align-items-center mt-3">
                        <input class="form-control form-control-sm" type="text" id="minSales" value="0" />
                        <span class="fw-semibold text-muted">a</span>
                        <input class="form-control form-control-sm" type="text" id="maxSales" value="10000" />
                    </div>
                </div>

                <!-- Filtro de Estados de Reserva -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="flush-headingStates">
                        <button class="accordion-button bg-transparent shadow-none" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapseStates"
                                aria-expanded="true" aria-controls="flush-collapseStates">
                            <span class="text-muted text-uppercase fs-12 fw-medium">Estados de Reserva</span>
                            <span class="badge bg-success rounded-pill align-middle ms-1 filter-badge"></span>
                        </button>
                    </h2>
                    <div id="flush-collapseStates" class="accordion-collapse collapse show"
                         aria-labelledby="flush-headingStates">
                        <div class="accordion-body text-body pt-0">
                            <div class="d-flex flex-column gap-2 mt-3 filter-check">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="RECONFIRMADO" id="stateReconfirmado" checked>
                                    <label class="form-check-label" for="stateReconfirmado">Reconfirmado</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="CONFIRMADO" id="stateConfirmado">
                                    <label class="form-check-label" for="stateConfirmado">Confirmado</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="ANULADO" id="stateAnulado">
                                    <label class="form-check-label" for="stateAnulado">Anulado</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Filtro de Personal -->
                <div class="accordion-item">
                    <h2 class="accordion-header" id="flush-headingPersonal">
                        <button class="accordion-button bg-transparent shadow-none collapsed" type="button"
                                data-bs-toggle="collapse" data-bs-target="#flush-collapsePersonal"
                                aria-expanded="false" aria-controls="flush-collapsePersonal">
                            <span class="text-muted text-uppercase fs-12 fw-medium">Estado Personal</span>
                            <span class="badge bg-success rounded-pill align-middle ms-1 filter-badge"></span>
                        </button>
                    </h2>
                    <div id="flush-collapsePersonal" class="accordion-collapse collapse"
                         aria-labelledby="flush-headingPersonal">
                        <div class="accordion-body text-body pt-1">
                            <div class="d-flex flex-column gap-2 filter-check">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="Actualizado" id="personalUpdated">
                                    <label class="form-check-label" for="personalUpdated">Datos Actualizados</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="No Actualizado" id="personalNotUpdated">
                                    <label class="form-check-label" for="personalNotUpdated">Datos No Actualizados</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel Principal -->
    <div class="col-xl-9 col-lg-8">


        <!-- Tabla de Clientes -->
        <div class="card">
            <div class="card-header border-0">
                <div class="row g-4">
                    <div class="col-sm-auto">
                        <div>
                            <h4 class="card-title mb-0" id="country-title">Selecciona un país</h4>
                        </div>
                    </div>
                    <div class="col-sm">
                        <div class="d-flex justify-content-sm-end">
                            <div class="search-box ms-2">
                                <input type="text" class="form-control" id="searchClientList" placeholder="Buscar Clientes...">
                                <i class="fas fa-search"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <ul class="nav nav-tabs-custom card-header-tabs border-bottom-0" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link active fw-semibold" data-bs-toggle="tab" href="#dashboard-tab" role="tab">
                                    Dashboard
                                    <span class="badge bg-primary align-middle rounded-pill ms-1" id="dashboard-count">
                                        <span id="dashboard-count-number">0</span>
                                        <i class="fas fa-hourglass-half fa-spin" id="dashboard-loading-icon" style="display: none;"></i>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#clients-tab" role="tab">
                                    Todos los Clientes
                                    <span class="badge bg-info align-middle rounded-pill ms-1" id="clients-count">
                                        <span id="clients-count-number">0</span>
                                        <i class="fas fa-hourglass-half fa-spin" id="clients-loading-icon" style="display: none;"></i>
                                    </span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link fw-semibold" data-bs-toggle="tab" href="#marketing-tab" role="tab">
                                    Clientes de Mercadeo
                                    <span class="badge bg-warning align-middle rounded-pill ms-1">
                                        <span>En construcción</span>
                                    </span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="tab-content text-muted">
                    <div class="tab-pane active" id="dashboard-tab" role="tabpanel">

                        <!-- Dashboard de Estadísticas -->
                        <div id="dashboard-section" style="display: none;">
                            <div class="row mb-4">
                                <div class="col-xl-3 col-sm-6">
                                    <div class="card stats-card stats-total">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <span class="text-muted mb-3 lh-1 d-block text-truncate">Total Reservas</span>
                                                    <h4 class="mb-3" id="total-reservas">0</h4>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <i class="fas fa-calendar-check fa-2x text-primary"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="card stats-card stats-reconfirmado">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <span class="text-muted mb-3 lh-1 d-block text-truncate">Reconfirmadas</span>
                                                    <h4 class="mb-3" id="total-reconfirmadas">0</h4>
                                                    <p class="text-muted mb-0"><span class="text-success fw-bold" id="precio-reconfirmadas">$0</span></p>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <i class="fas fa-check-circle fa-2x text-success"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="card stats-card stats-confirmado">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <span class="text-muted mb-3 lh-1 d-block text-truncate">Confirmadas</span>
                                                    <h4 class="mb-3" id="total-confirmadas">0</h4>
                                                    <p class="text-muted mb-0"><span class="text-warning fw-bold" id="precio-confirmadas">$0</span></p>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <i class="fas fa-clock fa-2x text-warning"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-xl-3 col-sm-6">
                                    <div class="card stats-card stats-anulado">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <span class="text-muted mb-3 lh-1 d-block text-truncate">Anuladas</span>
                                                    <h4 class="mb-3" id="total-anuladas">0</h4>
                                                    <p class="text-muted mb-0"><span class="text-danger fw-bold" id="precio-anuladas">$0</span></p>
                                                </div>
                                                <div class="flex-shrink-0">
                                                    <i class="fas fa-times-circle fa-2x text-danger"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-xl-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Cantidad de Clientes por Categoría</h5>
                                    </div>
                                    <div class="card-body">
                                        <canvas id="clientesReconfirmadasChart" width="400" height="500"></canvas>

                                    </div>
                                </div>
                            </div>



                        </div>
                        <div id="dashboard-content">
                            <div class="py-4 text-center">
                                <i class="fas fa-globe fa-4x text-muted mb-3"></i>
                                <h5 class="mt-4">Selecciona un país para ver el dashboard</h5>
                                <p class="text-muted">Usa el panel de filtros para seleccionar una región y país</p>
                            </div>
                        </div>

                        <!-- Loading state para dashboard -->
                        <div id="dashboard-loading" class="py-4 text-center" style="display: none;">
                            <lord-icon src="https://cdn.lordicon.com/msoeawqm.json"
                                       trigger="loop" colors="primary:#405189,secondary:#0ab39c"
                                       style="width:72px;height:72px">
                            </lord-icon>
                            <h5 class="mt-4">Cargando datos del país...</h5>
                            <p class="text-muted">Por favor espera mientras procesamos la información</p>
                        </div>
                    </div>

                    <div class="tab-pane" id="clients-tab" role="tabpanel">
                        <!-- Loading state para tabla de clientes -->
                        <div id="clients-loading" class="py-4 text-center" style="display: none;">
                            <lord-icon src="https://cdn.lordicon.com/msoeawqm.json"
                                       trigger="loop" colors="primary:#405189,secondary:#0ab39c"
                                       style="width:72px;height:72px">
                            </lord-icon>
                            <h5 class="mt-4">Cargando clientes...</h5>
                            <p class="text-muted">Procesando información de clientes</p>
                        </div>

                        <div class="table-responsive" id="clients-table-container">
                            <table class="table table-nowrap align-middle" id="clients-table">
                                <thead class="table-light">
                                    <tr>
                                        <th>Ranking</th>
                                        <th style="width: 15%;">Cliente</th>
                                        <th class="text-center">Chart</th>
                                        <th class="text-center">Total Personal</th>
                                        <th class="text-center">Comparativa</th>
                                        <th class="text-center">Ventas Totales</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="clients-table-body">
                                    <!-- Se llenará dinámicamente -->
                                </tbody>
                            </table>
                        </div>

                    </div>

                    <div class="tab-pane" id="marketing-tab" role="tabpanel">
                        <div class="py-4 text-center">
                            <i class="fas fa-tools fa-4x text-muted mb-3"></i>
                            <h5 class="mt-4">En Construcción</h5>
                            <p class="text-muted">Esta sección está siendo desarrollada</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>



<!-- Modal para Ver Personal -->
<!-- Ventana Draggable para Ver Personal -->
<div class="personal-window-container" id="personalWindowContainer" style="display: none;">
    <div class="personal-window" id="personalWindow">
        <div class="personal-window-header" id="personalDragHandle">
            <h5 class="personal-window-title">
                <i class="fas fa-users me-2"></i>
                Personal de <span id="client-name-window"></span>
            </h5>
            <button type="button" class="personal-close-btn" onclick="closePersonalWindow()">
                <i class="fas fa-times"></i>
            </button>
        </div>
        <div class="personal-window-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Personal</th>
                            <th>Estado</th>
                            <th>Contacto</th>
                            <th>Ventas Totales</th>
                            <th>Detalle</th>
                            <th>Mensajería</th>
                        </tr>
                    </thead>
                    <tbody id="personal-table-body">
                        <!-- Se llenará dinámicamente -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Ventana Drag and Drop para Detalle del Personal -->
<div class="draggable-window" id="personalDetailWindow">
    <div class="window-header" id="windowHeader">
        <h5 class="mb-0">Detalle de <span id="personal-detail-name-window"></span></h5>
        <button class="window-close" onclick="closePersonalDetailWindow()">×</button>
    </div>
    <div class="window-content">
        <!-- Chart combinado -->
        <!-- Chart combinado más pequeño -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0">Resumen Completo</h6>
                    </div>
                    <div class="card-body p-2">

                        <div style="height: 200px; position: relative;">
                            <canvas id="personalCompleteChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Paquetes más vendidos -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0">Paquetes Más Vendidos (Reconfirmadas)</h6>
                    </div>
                    <div class="card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <div id="paquetes-vendidos-window">
                            <!-- Se llenará dinámicamente -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header py-2">
                        <h6 class="mb-0">Ultimo Paquete (Reconfirmado)</h6>
                    </div>
                    <div class="card-body p-2" style="max-height: 250px; overflow-y: auto;">
                        <div id="paquetes-ultimo-vendidos-window">
                            <!-- Se llenará dinámicamente -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>




<!-- Modal de Mensajería -->
<div class="whsp-window-container" id="whspWindowContainer" style="display: none;">
    <div class="whsp-window" id="whspWindow">
        <div class="whsp-window-header" id="whspDragHandle">
            <h5 class="whsp-window-title text-white">
                <i class="fas fa-comments me-2"></i>
                Mensajería
            </h5>
            <button type="button" class="whsp-close-btn" onclick="closeWhspWindow()">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="whsp-window-body">
            <!-- Pestañas -->
            <ul class="nav nav-tabs px-3 pt-2" id="mensajeriaTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="whatsapp-tab" data-bs-toggle="tab" data-bs-target="#whatsapp" type="button" role="tab">
                        <i class="fab fa-whatsapp me-1"></i> WhatsApp
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="email-tab" data-bs-toggle="tab" data-bs-target="#email" type="button" role="tab">
                        <i class="fas fa-envelope me-1"></i> Correos
                    </button>
                </li>
            </ul>

            <!-- Contenido de las pestañas -->
            <div class="tab-content h-100" id="mensajeriaTabContent">
                <!-- Pestaña WhatsApp -->
                <div class="tab-pane fade show active h-100" id="whatsapp" role="tabpanel">
                    <div class="row g-0 h-100">
                        <!-- Sidebar Izquierdo -->
                        <div class="col-4 whsp-sidebar">
                            <!-- Buscador -->
                            <div class="whsp-search-container position-relative">
                                <i class="fas fa-search whsp-search-icon"></i>
                                <input type="text" class="whsp-search-input" id="whspSearchInput"
                                       placeholder="Buscar mensajes..."
                                       onkeyup="whspSearchMessages()">
                            </div>

                            <!-- Información del Cliente -->
                            <div class="whsp-sidebar-section">
                                <div class="whsp-sidebar-title">
                                    <i class="fas fa-user me-1"></i> Personal
                                </div>
                                <div class="whsp-contact-detail">
                                    <div class="whsp-contact-label">Nombre:</div>
                                    <div class="whsp-contact-value fw-bold" id="whspClientName">Juan Pérez</div>
                                </div>
                                <div class="whsp-contact-detail">
                                    <div class="whsp-contact-label">Teléfono:</div>
                                    @*<div class="whsp-contact-value text-success fw-bold" id="whspClientPhone">+51 999 888 777</div>*@
                                    <input type="tel"
                                           class="whsp-contact-input text-success fw-bold"
                                           id="whspClientPhone"
                                          
                                           placeholder="Número de teléfono">
                                </div>

                                <div class="whsp-contact-detail">
                                    <div class="whsp-contact-label">Estado:</div>
                                    <div class="whsp-contact-value text-success">
                                        <span class="whsp-online-indicator"></span>En línea
                                    </div>
                                </div>
                            </div>

                            <!-- Estadísticas -->
                            <div class="whsp-sidebar-section">
                                <div class="whsp-sidebar-title">
                                    <i class="fas fa-chart-line me-1"></i> Estadísticas
                                </div>
                                <div class="whsp-stats-container">
                                    <div class="whsp-stat-item">
                                        <div class="whsp-stat-number" id="whspMessagesSent">0</div>
                                        <div class="whsp-stat-label">Enviados</div>
                                    </div>
                                    <div class="whsp-stat-item">
                                        <div class="whsp-stat-number" id="whspClientResponses">0</div>
                                        <div class="whsp-stat-label">Respuestas</div>
                                    </div>
                                    <div class="whsp-stat-item">
                                        <div class="whsp-stat-number" id="whspActiveTime">00:00</div>
                                        <div class="whsp-stat-label">Tiempo</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Mensajes Rápidos -->
                            <div class="whsp-sidebar-section">
                                <div class="whsp-sidebar-title">
                                    <i class="fas fa-bolt me-1"></i> Mensajes Rápidos
                                </div>
                                <div>
                                    <button class="whsp-quick-btn" onclick="whspSendQuickMessage('saludo')">
                                        👋 Saludo
                                    </button>
                                    <button class="whsp-quick-btn" onclick="whspSendQuickMessage('oferta')">
                                        🎁 Oferta
                                    </button>
                                    <button class="whsp-quick-btn" onclick="whspSendQuickMessage('consulta')">
                                        📞 Consulta
                                    </button>
                                    <button class="whsp-quick-btn" onclick="whspSendQuickMessage('seguimiento')">
                                        🔄 Seguimiento
                                    </button>
                                    <button class="whsp-quick-btn" onclick="whspSendQuickMessage('urgente')">
                                        ⏰ Urgente
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Área Principal del Chat -->
                        <div class="col-8 d-flex flex-column">
                            <!-- Header del Chat -->
                            <div class="whsp-chat-header">
                                <div class="whsp-avatar" id="whspAvatar">JP</div>
                                <div class="whsp-contact-info flex-grow-1">
                                    <h6 id="whspHeaderName">Juan Pérez</h6>
