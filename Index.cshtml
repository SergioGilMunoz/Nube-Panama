                    cotizacionesConvertidas,
                    reconfirmadas.reduce((sum, r) => sum + r.total, 0),
                    confirmadas.reduce((sum, r) => sum + r.total, 0),
                    anuladas.reduce((sum, r) => sum + r.total, 0)
