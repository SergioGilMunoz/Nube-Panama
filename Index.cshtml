            //const paquetesHtml = paquetesArray.slice(0, 8).map(([paquete, cantidad]) => `
            //                                                        <div class="d-flex justify-content-between align-items-center py-1 border-bottom">
            //                                                            <span class="text-truncate small" style="max-width: 75%;" title="${paquete}">${paquete}</span>
