        function whspEnviarMensaje(datos, callback) {
            const currentTime = new Date().toLocaleString('es-ES', {
                day: '2-digit', month: 'short', year: '2-digit', hour: '2-digit', minute: '2-digit'
            });

            const chatMessageData = {
                from_Id: "1", to_Id: "2", mensaje: datos.mensaje, datetime: currentTime
            };

            let telefono = document.getElementById("whspClientPhone").value;

            const payload = {
                idCliente: whspCurrentClientData.idCliente,
                IdPersonal: whspCurrentClientData.idParaMensajeria,
                Telefono: telefono,
                nombrePersonal: whspCurrentClientData.personalNombre,
                ChatMessageData: chatMessageData
            };

            if (datos.tipo === 'archivo') {
                payload.ChatMessageData.archivoBase64 = datos.archivo.archivoBase64;
                payload.ChatMessageData.nombreArchivo = datos.archivo.nombreArchivo;
                payload.ChatMessageData.tipoArchivo = datos.archivo.tipoArchivo;
                payload.ChatMessageData.tamanoArchivo = datos.archivo.tamanoArchivo;
            }

            const url = datos.tipo === 'archivo'
                ? '/DashboardRerservas/EnviarArchivoPersonalCliente'
                : '/DashboardRerservas/EnviarMensajePersonalCliente';

            const btn = document.querySelector('.whsp-send-btn');
            const original = btn?.innerHTML;
            if (btn) {
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                btn.disabled = true;
            }

            fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                },
                body: JSON.stringify(payload)
            })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        const content = datos.tipo === 'archivo'
                            ? whspCreateFileMessage({ name: datos.archivo.nombreArchivo, type: datos.archivo.tipoArchivo }, datos.archivo.archivoBase64)
                            : datos.mensaje;
                        whspAddMyMessage(content, datos.tipo === 'archivo');
                        callback?.();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(() => alert('Error de conexión.'))
                .finally(() => {
                    if (btn) {
                        btn.innerHTML = original;
                        btn.disabled = false;
                    }
                    whspSending = false;
                });
        }

