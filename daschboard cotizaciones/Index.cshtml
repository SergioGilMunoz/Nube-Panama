        function BuscarCotizacionesSemana() {

            // Obtener los valores seleccionados en el select múltiple
            //  var clientesSeleccionados = $('#clienteBusquedaCotizacionesVencidasMultiple').val();
            const clientesSeleccionados = $('#clienteBusquedaCotizacionesSemanaMultiple').val().join(',');
            // Obtener el valor de la fecha seleccionada
            var fechaSeleccionada = $('#fechaCotizacionesSemana').val();
            if (!fechaSeleccionada) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Campos incompletos',
                    text: 'Por favor, seleccione una fecha para continuar.',
                    confirmButtonText: 'Entendido',
                });
                return;
            }

            var [periodo1, periodo2] = fechaSeleccionada.split(' al ');

            periodo1 = periodo1.trim();
            periodo2 = periodo2 ? periodo2.trim() : ''; // Asegúrate de que periodo2 tenga un valor

            // Comprobar si periodo2 está vacío
            if (!periodo2) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Rango de fechas incompleto',
                    text: 'Por favor, seleccione un rango de fechas completo (desde y hasta).',
                    confirmButtonText: 'Entendido',
                });
                return;
            }


            // Limpiar el cuerpo de la tabla
            const tbody = $('#customerTableCotizacionesSemana tbody');
            tbody.empty();
            $('.noresultCotizacionesSemana').show();

            // Enviar los datos al controlador usando AJAX
            $.ajax({
                type: 'POST',
                url: '/DASHBOARDSTYLE2/ClientesBusquedaCotizacionesSemana',  // Reemplaza con la URL de tu acción en el controlador
                data: {
                    cliente: clientesSeleccionados,
                    periodo1: periodo1,
                    periodo2: periodo2

                },
                traditional: true,  // Para enviar datos de array en AJAX
                success: function (response) {

                    if (response.success) {
                        renderTablaCotizacionesSemana(response.data)
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error en la solicitud',
                            text: 'Hubo un problema en el Servidor. Intente nuevamente.',
                            confirmButtonText: 'Cerrar',
                        });

                    }


                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error en la solicitud',
                        text: 'Hubo un problema al procesar la solicitud. Intente nuevamente.',
                        confirmButtonText: 'Cerrar',
                    });
                    console.error('Error en la solicitud:', error);
                }
            });
        }



        function renderTablaCotizacionesSemana(data) {
            dataparse = JSON.parse(data)
            // Limpiar el cuerpo de la tabla
            const tbody = $('#customerTableCotizacionesSemana tbody');
            tbody.empty();

            const cantidadResultados = dataparse.length;
            $('#total-result-cotizaciones-semana').text(`${cantidadResultados}`); // Mostrar el número de resultados

            // Iterar sobre cada objeto en el JSON para llenar la tabla
            dataparse.forEach(item => {
                const row = `
                                                                                    <tr>
                                                                                        <td class="text-start">
                                                                                        <a href="javascript:void(0)" class="text-primary cell-click2" data-id="${item.id_cliente}" data-fechadesde="${item.fecha_desde}" data-fechahasta="${item.fecha_hasta}" >${item.Cliente} (${item.Pais})</a>
                                                                                        </td>

                                                                                        <td class="text-center table-light">${item.Lunes}</td>
                                                                                        <td class="text-center">${item.Martes}</td>
                                                                                        <td class="text-center table-light">${item.Miercoles}</td>
                                                                                        <td class="text-center">${item.Jueves}</td>
                                                                                        <td class="text-center table-light">${item.Viernes}</td>
                                                                                        <td class="text-center">${item.Sabado}</td>
                                                                                        <td class="text-center table-light">${item.Domingo}</td>
                                                                                    </tr>
                                                                                `;
                tbody.append(row);
            });

            // Manejar el evento de clic en las celdas especificadas
            $('.cell-click2').on('click', function () {
                const idCliente = $(this).data('id');
                const fechaDesde = $(this).data('fechadesde');
                const fechaHasta = $(this).data('fechahasta');
               // const column = $(this).data('column');

                // Realizar la solicitud AJAX para obtener los datos del cliente
                $.ajax({
                    url: '/DASHBOARDSTYLE2/ObtenerDatosVencidasVencerporId',
                    type: 'POST',
                    data: { idCliente: idCliente, periodo1: fechaDesde, periodo2: fechaHasta},
                    success: function (response) {
                        const nombre = response.rutaImagenNombreId.nombre;
                        const idUsuario = response.rutaImagenNombreId.id_usuario;
                        const ruta = response.rutaImagenNombreId.ruta_relativa;
                        // Limpiar el datatable anterior del modal y llenarlo con nuevos datos
                        const table = $('#miModalTable').DataTable();
                        table.clear().draw();

                        // Agregar los nuevos datos al datatable
                        response.data.forEach(item => {

                            // Convertir las fechas de formato /Date(...)/
                            const fechaAlta = new Date(parseInt(item.fecha_alta.substr(6)));
                            const fechaVencimiento = new Date(parseInt(item.fecha_vencimiento.substr(6)));
                            //  if (item.fecha_viaje != null) { const fechaViaje = new Date(parseInt(item.fecha_viaje.substr(6))); }
                            const fechaViaje = new Date(parseInt(item.fecha_viaje.substr(6)));

                            // Formatear las fechas (por ejemplo, en formato 'DD/MM/YYYY')
                            const opcionesFecha = { year: 'numeric', month: '2-digit', day: '2-digit' };
                            const fechaAltaFormateada = fechaAlta.toLocaleDateString('es-ES', opcionesFecha);
                            const fechaVencimientoFormateada = fechaVencimiento.toLocaleDateString('es-ES', opcionesFecha);
                            const fechaViajeFormateada = fechaViaje.toLocaleDateString('es-ES', opcionesFecha);

                            //const nombreCotizacionCapitalizada = capitalizeWords(nombre_cotizacion)


                            table.row.add([
                                item.id_cotizacion,
                                capitalizeWords(item.nombre_cotizacion),
                                fechaAltaFormateada,
                                fechaVencimientoFormateada,
                                item.nombre_cliente,
                                item.counter_cliente,
                                item.dias_vencimiento,
                                fechaViajeFormateada,
                                item.counter_rge,
                                '', // Teléfono vacío
                                '',
                                '',
                                `<a href="javascript:void(0)" class="text-primary edit-icon" data-id="${item.id_cotizacion}" onclick="openEditModal('${item.id_cotizacion}', '${item.telefono}', '${item.correo}', '${item.counter_cliente}', '${item.idCliente}', '${nombre}', '${idUsuario}', '${ruta}', '${item.nombre_cotizacion}')">
                                 <i class="mdi mdi-email-fast fs-20"></i>
                             </a>`
                            ]).draw();
                        });

                        // Mostrar el modal
                        $('#modalCotizacion').modal('show');
                    },
                    error: function () {
                        alert('Error al obtener los datos del cliente.');
                    }
                });
            });





            $('.noresultCotizacionesSemana').hide();
        }




