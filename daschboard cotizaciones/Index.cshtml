        // PINTA LA GRAFICA
        function renderPieChart(selector, labels, series) {
            var options = {
                chart: {
                    type: 'pie',
                },
                series: series,
                labels: labels,
                colors: colors,
                legend: {
                    position: 'right'
                },
                dataLabels: {
                    enabled: true,
                    dropShadow: {
                        enabled: false
                    },
                    style: {
                        fontSize: '14px'
                    },
                    formatter: function (val, opts) {
                        const seriesValue = opts.w.config.series[opts.seriesIndex];
                        return Math.round(val) + '% (' + seriesValue + ')';
                    }
                }
            };

            var chart = new ApexCharts(document.querySelector(selector), options);
            chart.render();
        }



