        function enviarLink() {
            var enviarBtn = document.getElementById("enviarBtn");
            var originalContent = enviarBtn.innerHTML;

            var mensaje = quill.root.innerHTML;
            var idCotizacion = $('#idCotizacionMensaje').text();
            var idCliente = $('#idClienteMensaje').text();
            var destinatario = document.getElementById("emailSelect").value;

            if (!destinatario || destinatario.trim() === "") {
                Swal.fire({
                    title: "Correo requerido",
                    text: "Por favor, ingresa un correo de destinatario.",
                    icon: "warning",
                    confirmButtonText: "Aceptar"
                });
                return;
            }

            if (!mensaje || mensaje.trim() === "<p><br></p>") {
                Swal.fire({
                    title: "Mensaje requerido",
                    text: "Por favor, ingresa un mensaje en el editor.",
                    icon: "warning",
                    confirmButtonText: "Aceptar"
                });
                return;
            }

            Swal.fire({
                title: "¿Enviar correo?",
                text: "¿Estás seguro de enviar este correo al destinatario?",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Sí, enviar Correo ",
                cancelButtonText: "No enviar Correo"
            }).then((result) => {
                if (result.isConfirmed) {
                    // Puedes personalizar este link como desees
                    let linkCotizacion = `<p><a href="https://tusitio.com/cotizacion/${idCotizacion}" target="_blank">Ver Cotización</a></p>`;
                    mensaje += linkCotizacion;
                }

                enviarBtn.innerHTML = `
            <span class="d-flex align-items-center">
                <span class="spinner-border spinner-border-sm flex-shrink-0" role="status">
                    <span class="visually-hidden">Enviando...</span>
                </span>
                <span class="flex-grow-1 ms-2">Enviando...</span>
            </span>`;
                enviarBtn.disabled = true;

                $.ajax({
                    url: '/DASHBOARDSTYLE2/EnviarCorreo',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        correo: destinatario,
                        mensaje: mensaje,
                        idCotizacion: idCotizacion
                    }),
                    success: function (response) {
                        if (response.success) {
                            $('.noHayCorreos').hide();
                            renderCorreoCotizaciones(response.data);
                            Swal.fire({
                                title: "¡Correo Enviado!",
                                text: "El mensaje se ha enviado correctamente.",
                                icon: "success",
                                confirmButtonText: "Aceptar"
                            });
                        } else {
                            Swal.fire({
                                title: "Error",
                                text: response.errorMessage || "Hubo un error al enviar el correo. Inténtalo nuevamente.",
                                icon: "error",
                                confirmButtonText: "Aceptar"
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            title: "Error",
                            text: "No se pudo contactar con el servidor. Por favor, inténtalo más tarde.",
                            icon: "error",
                            confirmButtonText: "Aceptar"
                        });
                    },
                    complete: function () {
                        enviarBtn.innerHTML = originalContent;
                        enviarBtn.disabled = false;
                    }
                });
            });
