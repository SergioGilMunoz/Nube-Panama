    <style>
        .vertical-text {
            writing-mode: vertical-rl;
            text-orientation: mixed;
            transform: rotate(180deg);
            white-space: nowrap;
            text-align: center; /* Centrar texto horizontalmente */
            vertical-align: middle; /* Centrar texto verticalmente */

            color: white !important; /* Color blanco */
            letter-spacing: 3px; /* Espaciado entre letras */
            text-transform: uppercase; /* Convertir a mayúsculas */
        }

        td, th {
            text-align: center; /* Centrar texto horizontalmente */
            vertical-align: middle; /* Centrar texto verticalmente */
        }

        .plomo-claro {
            background-color: #f5f5f5 !important; /* Color plomo claro */
        }


        .close-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: red;
            color: white;
            border: none;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }

        /*
        .apexcharts-legend {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
        }*/

        .table-container {
            max-height: 620px; /* Ajusta esta altura según tus necesidades */
            overflow-y: auto;
            border: 1px solid #dee2e6; /* Opcional: agrega un borde alrededor del contenedor */
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        thead th {
            position: sticky;
            top: 0;
            background-color: white;
            z-index: 2; /* Asegura que la cabecera esté siempre por encima de las filas */
            border-bottom: 1px solid #dee2e6; /* Asegura que el borde inferior de la cabecera se vea bien */
            padding: 8px; /* Agrega un poco de relleno para que el texto no esté pegado al borde */
            text-align: left; /* Alinea el texto a la izquierda */
        }

        tbody td {
            padding: 8px; /* Agrega un poco de relleno a las celdas */
            border-bottom: 1px solid #dee2e6; /* Agrega un borde inferior a las filas */
        }

        .fixed-width {
            width: 150px !important; /* Ajusta el valor según tus necesidades */
        }

        .no-padding-cells th,
        .no-padding-cells td {
            padding: 5px;
        }

        .flatpickr-input {
            width: 230px !important; /* Adjust the width as needed */
