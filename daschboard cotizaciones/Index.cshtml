        function renderTablaCotizacionesVencidas(data) {
            const dataparse = JSON.parse(data);
            const tbody = $('#customerTableCotizaciones tbody');
            tbody.empty();

            const cantidadResultados = dataparse.length;
            $('#total-result-cotizaciones-vencidas').text(`${cantidadResultados}`);

            dataparse.forEach(item => {
                const total =
                    (parseInt(item.C13xvencer) || 0) +
                    (parseInt(item.C46xvencer) || 0) +
                    (parseInt(item.C7xvencer) || 0) +
                    (parseInt(item.Vence_hoy) || 0) +
                    (parseInt(item.C13xvencida) || 0) +
                    (parseInt(item.C46xvencida) || 0) +
                    (parseInt(item.C7xvencida) || 0);

                const totalBarraProgrees = (parseInt(item.Vence_hoy) || 0) +
                    (parseInt(item.C13xvencida) || 0) +
                    (parseInt(item.C46xvencida) || 0) +
                    (parseInt(item.C7xvencida) || 0);


                //const progreso = Math.round((item.notificados / totalBarraProgrees) * 100);
                //let colorBarra;
                //if (progreso <= 20) {
                //    colorBarra = "bg-danger";
                //} else if (progreso <= 70) {
                //    colorBarra = "bg-warning";
                //} else if (progreso === 100) {
                //    colorBarra = "bg-success";
                //}

                const progreso = item.notificados > 0 ? Math.round((totalBarraProgrees / item.notificados) * 100) : 0;

                let colorBarra;
                let anchoBarra;

                if (progreso === 0) {
                    colorBarra = "bg-danger"; // Color rojo si progreso es 0.
                    anchoBarra = 100; // Barra llena al 100%.
                } else {
                    anchoBarra = progreso; // Si no es 0, la barra toma el valor real del progreso.

                    if (progreso <= 20) {
                        colorBarra = "bg-danger";
                    } else if (progreso <= 70) {
                        colorBarra = "bg-warning";
                    } else if (progreso === 100) {
                        colorBarra = "bg-success";
                    } else {
                        colorBarra = "bg-primary"; // Color opcional para valores entre 71 y 99.
                    }
                }






                const progressBarHtml = `
            <div class="row align-items-center g-2">
                <div class="col-auto">
