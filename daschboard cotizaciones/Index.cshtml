        function Datos(region, pais, cliente, estado, year, yearCompara,) {

            $.ajax({
                url: '/DASHBOARDSTYLE2/Datos', // Cambia '/TuControlador' por la ruta correcta a tu controlador
                type: 'POST',
                data: {
                    Cliente: cliente,
                    Region: region,
                    Pais: pais,
                    Estado: estado,
                    Periodo1: year,
                    Periodo2: yearCompara,
                    //Modo: modo,
                    //proyeccion: proyeccion
                },
                dataType: 'json',
                success: function (response) {
                    if (response.success) {
                        const data = JSON.parse(response.data); // Analiza la cadena JSON a un objeto
                        populateRegions(data)
                        populateCountries(data)
                        //  $('select').show();
                        populateTable(data);

                    } else {
                        console.error('Error del servidor:', response.message);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Error al obtener los datos del servidor:', error);
                }
            });
        }

        // CARGA DE INFORMACION EL COMBO REGION
        function populateRegions(data) {
            const regionSelect = $('#region');
            regionSelect.empty();

            // Agregar opción vacía
            //   regionSelect.append(new Option('Seleccione una región', '', true, true));

            data.forEach(region => {
                const option = new Option(region.name, region.id, false, false);
                regionSelect.append(option);
            });

            regionSelect.trigger('change');
        }


        // CARGA DE INFORMACION EL COMBO PAIS
        function populateCountries(data) {
            const countrySelect = $('#pais');
            countrySelect.empty();

            // Agregar opción vacía
            //   countrySelect.append(new Option('Seleccione un país', '', true, true));

            data.forEach(region => {
                region.countries.forEach(country => {
                    const option = new Option(country.name, country.id, false, false);
                    countrySelect.append(option);
                });
            });

            countrySelect.trigger('change');
            // se pueden ver  todos los select y desaparece el placehoulder

            $('.placeholder').hide();
            iniciarCombos()

        }

