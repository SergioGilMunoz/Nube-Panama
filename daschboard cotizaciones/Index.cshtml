        function BuscarCotizacionesVencidas() {

            // Obtener los valores seleccionados en el select múltiple
            //  var clientesSeleccionados = $('#clienteBusquedaCotizacionesVencidasMultiple').val();
            const clientesSeleccionados = $('#clienteBusquedaCotizacionesVencidasMultiple').val().join(',');
            // Obtener el valor de la fecha seleccionada
            var fechaSeleccionada = $('#fechaCotizacionesVencidas').val();
            // Comprobar si hay datos seleccionados antes de enviar
            if (!fechaSeleccionada) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Campos incompletos',
                    text: 'Por favor, seleccione una fecha para continuar.',
                    confirmButtonText: 'Entendido',
                });
                return;
            }

            var [periodo1, periodo2] = fechaSeleccionada.split(' al ');

            periodo1 = periodo1.trim();
            periodo2 = periodo2 ? periodo2.trim() : ''; // Asegúrate de que periodo2 tenga un valor

            // Comprobar si periodo2 está vacío
            if (!periodo2) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Rango de fechas incompleto',
                    text: 'Por favor, seleccione un rango de fechas completo (desde y hasta).',
                    confirmButtonText: 'Entendido',
                });
                return;
            }

            // Limpiar el cuerpo de la tabla
            const tbody = $('#customerTableCotizaciones tbody');
            tbody.empty();
            $('.noresultCotizacionesVencidas').show();


            // Enviar los datos al controlador usando AJAX
            $.ajax({
                type: 'POST',
                url: '/DASHBOARDSTYLE2/ClientesBusquedaCotizacionesVencidas',  // Reemplaza con la URL de tu acción en el controlador
                data: {
                    cliente: clientesSeleccionados,
                    periodo1: periodo1,
                    periodo2: periodo2

                },
                traditional: true,  // Para enviar datos de array en AJAX
                success: function (response) {

                    if (response.success) {
                        renderTablaCotizacionesVencidas(response.data)
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error en la solicitud',
                            text: 'Hubo un problema en el Servidor. Intente nuevamente.',
                            confirmButtonText: 'Cerrar',
                        });

                    }

                },
                error: function (xhr, status, error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error en la solicitud',
                        text: 'Hubo un problema al procesar la solicitud. Intente nuevamente.',
                        confirmButtonText: 'Cerrar',
                    });
                    console.error('Error en la solicitud:', error);
                }
            });
        }



