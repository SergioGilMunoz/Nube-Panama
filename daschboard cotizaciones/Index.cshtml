                        <div class="progress bg-success-subtle animated-progress progress-sm">
                            <div class="progress-bar ${colorBarra}" role="progressbar" 
                                style="width: ${anchoBarra}%;" 
                                aria-valuenow="${progreso}" 
                                aria-valuemin="0" 
                                aria-valuemax="100">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-auto">
