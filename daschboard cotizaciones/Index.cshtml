            const tbody = $('#customerTableCotizacionesLog tbody');
            tbody.empty();
            // Meses en formato abreviado
            const monthNames = ["Ene", "Feb", "Mar", "Abr", "May", "Jun", "Jul", "Ago", "Sep", "Oct", "Nov", "Dic"];

            const cantidadResultados = dataparse.length;
            $('#total-result-cotizaciones-log').text(`${cantidadResultados}`); // Mostrar el número de resultados


            // Iterar sobre cada objeto en el JSON para llenar la tabla
            dataparse.forEach(item => {

                const inicioDate = new Date(item.inicioViaje);
                const formattedInicioDate = `${inicioDate.getDate()} ${monthNames[inicioDate.getMonth()]} ${inicioDate.getFullYear()}`;

                const finDate = new Date(item.finViaje);
                const formattedFinDate = `${finDate.getDate()} ${monthNames[finDate.getMonth()]} ${finDate.getFullYear()}`;

                const notificacion1Date = new Date(item.fechaNotificacion1);
                const formattednotificacion1Date = `${notificacion1Date.getDate()} ${monthNames[notificacion1Date.getMonth()]} ${notificacion1Date.getFullYear()}`;

                const notificacion2Date = new Date(item.fechaNotificacion2);
                const formattednotificacion2Date = `${notificacion2Date.getDate()} ${monthNames[notificacion2Date.getMonth()]} ${notificacion2Date.getFullYear()}`;



                const row = `
                                                                                    <tr>
                                                                                        <td class="text-start table-light">${item.Cliente}</td>
                                                                                        <td class="text-start ">${item.nombreCotizacion}</td>
                                                                                        <td class="text-center table-light">${formattedInicioDate}</td>
                                                                                        <td class="text-center ">${formattedFinDate}</td>
                                                                                        <td class="text-center table-light">${formattednotificacion1Date}</td>
                                                                                        <td class="text-center ">${item.respuestaNotificacion1}</td>
                                                                                        <td class="text-center table-light">${formattednotificacion2Date}</td>
                                                                                        <td class="text-center ">${item.respuestaNotificacion2}</td>
                                                                                        <td class="text-center table-light">${item.correoParte1}<br>${item.correoParte2}</td>

                                                                                        <td class="text-center ">${item.telefono}</td>
                                                                                        <td class="text-center table-light">${item.counterCliente}</td>
