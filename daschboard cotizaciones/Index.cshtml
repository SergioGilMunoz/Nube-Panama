        function renderCorreoCotizaciones(jsonCorreos) {

            var correos = JSON.parse(jsonCorreos)
            document.querySelector('.correosGuardados').innerHTML = '';

            // Iterar sobre los correos y renderizarlos
            correos.forEach((correo, index) => {
                const contenidoMensaje = correo.mensaje.map(linea => `<p>${linea}</p>`).join("");
                const correoHTML = `
    <section class="accordion-item right">
        <div class="accordion-header">
            <a role="button" class="btn w-100 text-start px-0 bg-transparent shadow-none collapsed" 
               data-bs-toggle="collapse" href="#correo-collapse${index}" aria-expanded="true" 
               aria-controls="correo-collapse${index}">
                <div class="d-flex align-items-center text-muted">
                    <div class="flex-shrink-0 avatar-xs me-3">
                        <img src="${correo.avatarRemitente}" alt="" class="img-fluid rounded-circle">
                    </div>
                    <div class="flex-grow-1 overflow-hidden">
                        <h5 class="fs-14 text-truncate email-user-name-right mb-0">${correo.nombreRemitente}</h5>
                        <div class="text-truncate fs-12">para: ${correo.emailDestinatario}</div>
                    </div>
                    <div class="flex-shrink-0 align-self-start">
                        <div class="text-muted fs-12">${correo.fecha}</div>
                    </div>
                </div>
            </a>
        </div>
        <div id="correo-collapse${index}" class="accordion-collapse collapse">
            <article class="accordion-body text-body px-0">
                ${contenidoMensaje}
            </article>
        </div>
    </section>
`;
                // Insertar el HTML en el contenedor con clase correosGuardados
                document.querySelector('.correosGuardados').innerHTML += correoHTML;
            });
        }



    </script>


