        // realiza el proceso de sumas de las regiones paises y clientes para la grafica
        function processData(processedData, selectedChart) {
            const data = processedData;

            if (selectedChart === "1") {
                // Sumar por país
                const result = data.map(region => {
                    const totalPerCountry = region.countries.map(country => {
                        const total = country.clients.reduce((acc, client) => {
                            return acc + Object.values(client.values).reduce((sum, value) => sum + value.total_periodo_actual, 0);
                        }, 0);

                        return { country: country.name, total };
                    });

                    return {
                        region: region.name,
                        totals: totalPerCountry
                    };
                });
                return result;

            } else if (selectedChart === "2") {
                // Sumar por región
                const result = data.map(region => {
                    const total = region.countries.reduce((acc, country) => {
                        return acc + country.clients.reduce((sum, client) => {
                            return sum + Object.values(client.values).reduce((innerSum, value) => innerSum + value.total_periodo_actual, 0);
                        }, 0);
                    }, 0);

                    return {
                        region: region.name,
                        total
                    };
                });
                return result;

            } else if (selectedChart === "0") {
                // Sumar por cliente
                const clientSums = data.flatMap(region =>
                    region.countries.flatMap(country =>
                        country.clients.map(client => {
                            const total = Object.values(client.values).reduce((sum, value) => sum + value.total_periodo_actual, 0);
                            return {
                                region: region.name,
                                country: country.name,
                                client: client.name,
                                total
                            };
                        })
                    )
                );
                return clientSums;
            }

            return []; // Retorna un array vacío si el selector no coincide
        }


        function processAreaChartData(json) {
            const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];
            const months = [];
            const actualTotals = [];
            const previousTotals = [];

            var data = json[0]; // Asegúrate de tomar el primer objeto del array

            data.countries.forEach(country => {
                country.clients.forEach(client => {
                    Object.keys(client.values).forEach(month => {
                        const monthIndex = parseInt(month) - 1; // Para obtener el índice del mes (0-11)

                        // Asegúrate de que el mes esté en el array
                        if (!months[monthIndex]) {
                            months[monthIndex] = monthNames[monthIndex]; // Guardar el nombre del mes
                        }

                        // Agregar los totales
                        if (!actualTotals[monthIndex]) {
                            actualTotals[monthIndex] = 0;
                        }
                        actualTotals[monthIndex] += client.values[month].total_periodo_actual;

                        if (!previousTotals[monthIndex]) {
                            previousTotals[monthIndex] = 0;
                        }
                        previousTotals[monthIndex] += client.values[month].total_periodo_anterior;
                    });
                });
            });

            return {
                months: months,
                actualTotals: actualTotals,
                previousTotals: previousTotals
            };
        }



