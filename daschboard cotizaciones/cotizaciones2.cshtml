        // Función para convertir formato de fecha "/Date(1740439999533)/" a objeto Date
        function parsearFechaJSON(fechaStr) {
            if (!fechaStr) return null;

            // Extraer el timestamp
            const matches = fechaStr.match(/\/Date\((\d+)\)\//);
            if (!matches || matches.length < 2) return null;

            // Crear un objeto Date con el timestamp
            return new Date(parseInt(matches[1]));
        }

        // Función para formatear fechas
        function formatFecha(fecha) {
            if (!fecha) return '-';

            return fecha.toLocaleDateString('es-ES', {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric'
            });
        }

        // Función para determinar si una fecha está vencida
        function estaVencida(fechaStr) {
            const fecha = parsearFechaJSON(fechaStr);
            if (!fecha) return false;

            const hoy = new Date();
            return fecha < hoy;
        }


