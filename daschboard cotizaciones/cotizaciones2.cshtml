        // Variable para almacenar el identificador del intervalo
        let serializedInterval;

        function openEditModal(idCotizacion, telefono, correo,miCorreo, counterCliente, idCliente, nombre, idusuario, ruta, nombreCotizacion, url,correoCounterRGE,idCounterRGE ) {

            // Selecciona el contenedor
            var chatConversationList = document.getElementById("users-conversation");

            // se borra el contenedor de dodne estan la lista de correos enviados
            document.querySelector('.correosGuardados').innerHTML = '';
            // Borra el contenido actual del contenedor
            chatConversationList.innerHTML = '';

            // Asigna el valor al campo de idCotizacion
            $('#idUsuario').text(idusuario);
            $('#nombreUsuario').text(nombre);
            $('#rutaImagen').text(ruta);
          //  $('#emailSelectRemitente').val(miCorreo);
            $('#emailSelectRemitente').val(correoCounterRGE);
            $('#idCounterRGE').val(idCounterRGE);

            $('#idCotizacionMensaje').text(idCotizacion);
            $('#counterCLiente').text(counterCliente);
            $('#idClienteMensaje').text(idCliente);

            $('#url').text(url);

            var nombreCotizacionCapitalizada = capitalizeWords(nombreCotizacion);
            $('.nombreCotizacionMensaje').text(nombreCotizacionCapitalizada);

            // Asigna el valor al campo de teléfono, o muestra un mensaje si no se encuentra.
            const telefonoChat = document.getElementById("telefonoChat");
            telefonoChat.value = telefono && telefono.trim() ? telefono : "no se encontró teléfono";
            // esto sirve para desactivar el tab en caso de q no haya numero de telefono
            // actualizarTabs()


            // Obtén el elemento del select para el correo
            const emailSelect = $('#emailSelect');
            // Limpia cualquier opción previa en el select usando Select2
            emailSelect.empty();

            // Agrega el correo al select
            if (correo) {
                const option = new Option(correo, correo, true, true); // 'true' selecciona el valor automáticamente
                emailSelect.append(option);
            } else {
                const option = new Option("no se encontró correo", "no_se_encontro_correo", true, true);
                emailSelect.append(option);
            }

            // Actualiza Select2 para reflejar los cambios
            emailSelect.trigger('change');
            // borra el contenedor de la mensajeria de correo
            quill.setContents([]);

            $.ajax({
                url: '/DASHBOARDSTYLE2/ObtenerConversacion',
                type: 'POST',
                data: { idCotizacion: idCotizacion },
                success: function (response) {
                    const conversaciones = response.jsonConversaciones;
                    if (conversaciones) {
                        getChatMessages(conversaciones); // Llama a la función por primera vez
                        fetchSerializedMessages();
                    }

                    const correos = response.data;
                    if (correos) {
                        $('.noHayCorreos').hide();
                        renderCorreoCotizaciones(correos)
                    } else { $('.noHayCorreos').show(); }

                }
            });

            // Muestra el modal
            $('#editMessageModal').modal('show');

            // Función para obtener el serialized cíclicamente
            function fetchSerializedMessages() {
                $.ajax({
                    url: '/DASHBOARDSTYLE2/ObetnerSerializedMaytapi',
                    type: 'POST',
                    data: { idCotizacion: idCotizacion },
                    success: function (response) {
                        const conversaciones = response.jsonConversaciones;
                        if (conversaciones) { getChatMessages(conversaciones); }
                    },
                    error: function (xhr, status, error) {
                        console.error("Error al obtener mensajes:", error);
                    }
                });
            }



            // Configura un intervalo para llamar a la función cada 60 segundos
            serializedInterval = setInterval(fetchSerializedMessages, 3000);

            // Detener el intervalo al cerrar el modal
            $('#editMessageModal').on('hidden.bs.modal', function () {
                if (serializedInterval) {
                    clearInterval(serializedInterval);
                    serializedInterval = null; // Reinicia la variable para evitar conflictos
                }
            });
        }




        function actualizarTabs() {
