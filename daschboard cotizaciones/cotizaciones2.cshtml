        function populateTable(data) {
            const tableBody = document.querySelector('#customerTable tbody');
            tableBody.innerHTML = '';

            let totalRows = 0;

            data.forEach((region) => {
                let regionRendered = false;
                let regionRowSpan = region.countries.reduce((sum, country) => sum + country.clients.length, 0); // Removed +1 for the sum row
                const regionColor = getRandomColor();

                region.countries.forEach((country) => {
                    let countryRendered = false;
                    const countryColor = getRandomColor();

                    country.clients.forEach((client) => {
                        const row = document.createElement('tr');

                        // Añadir celda de región solo en la primera fila del grupo de región
                        if (!regionRendered) {
                            const regionCell = document.createElement('td');
                            regionCell.textContent = region.name;
                            regionCell.rowSpan = regionRowSpan;
                            regionCell.style.backgroundColor = regionColor;
                            regionCell.classList.add('vertical-text');
                            row.appendChild(regionCell);
                            regionRendered = true;
                        }

                        // Añadir celda de país solo en la primera fila del grupo de país
                        if (!countryRendered) {
                            const countryCell = document.createElement('td');
                            countryCell.textContent = country.name;
                            countryCell.rowSpan = country.clients.length;
                            countryCell.style.backgroundColor = countryColor;
                            countryCell.classList.add('vertical-text');
                            row.appendChild(countryCell);
                            countryRendered = true;
                        }

                        // Añadir celda de cliente y valores mensuales
                        const values = client.values;

                        const createCell = (value, index) => {
                            const totalSolicitadas = value?.total_cantidad_solicitadas || 0;
                            const totalRevisar = value?.total_catindad_a_revisar || 0;
                            const totalVencidas = value?.total_cantidad_vencidas || 0;

                            // Aplicar la clase 'plomo-claro' si el índice es impar
                            const className = index % 2 !== 0 ? 'plomo-claro' : '';

                            let cellContent = `<td class="${className}">${totalSolicitadas}<br>${totalRevisar}<br>${totalVencidas}</td>`;

                            return cellContent;
                        };

                        row.innerHTML += `
                                                                                                <td width=3rem>${client.name}</td>
                                                                                                <td>Solicitadas<br>Revision<br>Vencidas</td>
                                                                                                ${createCell(values["1"], 1)}
                                                                                                ${createCell(values["2"], 2)}
                                                                                                ${createCell(values["3"], 3)}
                                                                                                ${createCell(values["4"], 4)}
                                                                                                ${createCell(values["5"], 5)}
                                                                                                ${createCell(values["6"], 6)}
                                                                                                ${createCell(values["7"], 7)}
                                                                                                ${createCell(values["8"], 8)}
                                                                                                ${createCell(values["9"], 9)}
                                                                                                ${createCell(values["10"], 10)}
                                                                                                ${createCell(values["11"], 11)}
                                                                                                ${createCell(values["12"], 12)}
                                                                                                ${createCell({
                            total_cantidad_solicitadas: calculateTotal(client.values, 'total_cantidad_solicitadas'),
                            total_cantidad_a_revisar: calculateTotal(client.values, 'total_cantidad_a_revisar'),
                            total_cantidad_vencidas: calculateTotal(client.values, 'total_cantidad_vencidas')
                        }, 13)}  `;
                        tableBody.appendChild(row);
                        totalRows++;
                    });
                });
            });

            // Update total result count
            document.getElementById('total-result-Tarifa').textContent = totalRows;
            // es el icono se lupa
            $('.noresult').hide();
        }

