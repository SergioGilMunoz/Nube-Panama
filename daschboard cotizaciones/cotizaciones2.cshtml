                    if (filaProcesada.length > 0) {
                        // Calcular la posición para centrar la fila en la pantalla
                        var alturaVentana = $(window).height();
                        var posicionFila = filaProcesada.offset().top;
                        var alturaFila = filaProcesada.outerHeight();

                        // Calcular el scroll para centrar la fila
                        var scrollTarget = posicionFila - (alturaVentana / 2) + (alturaFila / 2);

                        // Scroll suave hacia la fila centrada
                        $('html, body').animate({
                            scrollTop: scrollTarget
