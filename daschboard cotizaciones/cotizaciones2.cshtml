        // Función para buscar cotizaciones por ID
        function buscarCotizaciones() {
            var valorBusqueda = $('#busquedaCotizaciones').val().trim();

            // Si está vacío, mostrar todo
            if (valorBusqueda === '') {
                mostrarTodo();
                return;
            }

            var encontrado = false;

            // Recorrer todas las filas de clientes
            $('.cliente-row').each(function () {
                var $filaCliente = $(this);
                var index = $filaCliente.data('index');
                var $filaDetalles = $(`.detalles-row[data-index="${index}"]`);
                var $contenedorDetalles = $(`#detalles-${index}`);

                var tieneCoincidencia = false;

                // Buscar en las filas de cotizaciones dentro de los detalles
                $filaDetalles.find('tr[data-cotizacion-id]').each(function () {
                    var $filaCotizacion = $(this);
                    var idCotizacion = $filaCotizacion.data('cotizacion-id').toString();

                    // Verificar si el ID contiene el valor buscado
                    if (idCotizacion.includes(valorBusqueda)) {
                        $filaCotizacion.show();
                        tieneCoincidencia = true;
                        encontrado = true;
                    } else {
                        $filaCotizacion.hide();
                    }
                });

                // Mostrar u ocultar el cliente según si tiene coincidencias
                if (tieneCoincidencia) {
                    $filaCliente.show();
                    $filaDetalles.show();

                    // Expandir automáticamente los detalles
                    $contenedorDetalles.show();
                    var $btnToggle = $filaCliente.find('.btn-toggle');
                    var $icon = $btnToggle.find('i');
                    $icon.removeClass('bi-chevron-down').addClass('bi-chevron-up');
                    $btnToggle.html('<i class="bi bi-chevron-up"></i> Ocultar detalles');
                } else {
                    $filaCliente.hide();
                    $filaDetalles.hide();
                }
            });

            // Mostrar mensaje si no se encontró nada
            if (!encontrado) {
                mostrarMensajeNoEncontrado();
            } else {
                ocultarMensajeNoEncontrado();
            }
        }

        // Función para mostrar todo
        function mostrarTodo() {
            $('.cliente-row').show();
            $('.detalles-row').show();
            $('.detalles-row').find('tr[data-cotizacion-id]').show();

            // Contraer todos los detalles
            $('.detalles-container').hide();
            $('.btn-toggle').each(function () {
                var $btnToggle = $(this);
                var $icon = $btnToggle.find('i');
                $icon.removeClass('bi-chevron-up').addClass('bi-chevron-down');
                $btnToggle.html('<i class="bi bi-chevron-down"></i> Ver detalles');
            });

            ocultarMensajeNoEncontrado();
        }

        // Función para mostrar mensaje de no encontrado
        function mostrarMensajeNoEncontrado() {
            if ($('#mensajeNoEncontrado').length === 0) {
                $('#clientesBody').append(`
            <tr id="mensajeNoEncontrado">
                <td colspan="6" class="text-center py-4">
                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-search"></i>
                        <strong>No se encontraron cotizaciones</strong> con el ID: <strong>${$('#busquedaCotizaciones').val()}</strong>
                    </div>
                </td>
            </tr>
        `);
            }
        }

        // Función para ocultar mensaje de no encontrado
        function ocultarMensajeNoEncontrado() {
            $('#mensajeNoEncontrado').remove();
        }

        // Evento para búsqueda en tiempo real mientras escribes
        $(document).ready(function () {
            $('#busquedaCotizaciones').on('keyup', function (e) {
                // Si presiona Enter, ejecutar búsqueda
                if (e.keyCode === 13) {
                    buscarCotizaciones();
                } else {
                    // Búsqueda en tiempo real (opcional, puedes comentar esto si prefieres solo con Enter o botón)
                    buscarCotizaciones();
                }
            });

            // Limpiar búsqueda al borrar todo el input
            $('#busquedaCotizaciones').on('input', function () {
                if ($(this).val().trim() === '') {
                    mostrarTodo();
                }
            });
        });

        // Función opcional: Limpiar búsqueda con botón
        function limpiarBusqueda() {
            $('#busquedaCotizaciones').val('');
            mostrarTodo();
        }








    </script>


}