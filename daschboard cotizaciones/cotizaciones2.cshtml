        class ContadorRemitentes {
            constructor() {
                this.ventana = document.getElementById('floatingWindow');
                this.datosOriginales = [];
                this.remitentesPorNombre = {};

                this.initEventListeners();
            }

            initEventListeners() {
                // Abrir/cerrar ventana
                //$('#openWindow').on('click', () => this.show());
                //$('#closeWindow').on('click', () => this.hide());

                // Búsqueda
                $('#buscarBtn').on('click', () => this.buscarRemitentes());
                $('#fechaBusqueda').on('keypress', (e) => {
                    if (e.which === 13) this.buscarRemitentes();
                });

           
            }

      

            buscarRemitentes() {
                const fecha = $('#fechaBusqueda').val();

                if (!fecha) {
                    this.mostrarError('Selecciona una fecha para buscar.');
                    return;
                }

                this.mostrarCargando(true);
                this.resetearEstados();

                // Crear la fecha sin conversión de zona horaria
                // Usar la fecha tal como la seleccionó el usuario
                const [year, month, day] = fecha.split('-');
                const fechaLocal = new Date(parseInt(year), parseInt(month) - 1, parseInt(day));

                // Formatear directamente sin toISOString() para evitar problemas de zona horaria
                const requestData = {
                    fechaBusquedaCorreo: fechaLocal
                };

                $.ajax({
                    url: '/DASHBOARDSTYLE2/conteoDeCorreosEnviados',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(requestData),
                    success: (data) => {
                        this.mostrarCargando(false);
                        if (data.success && data.data && data.data.length > 0) {
                            this.procesarYMostrarRemitentes(data.data, fecha);
                        } else {
                            $('#sinResultados').removeClass('hidden');
                        }
                    },
                    error: (xhr, status, error) => {
                        this.mostrarCargando(false);
                        this.mostrarError('Error en la búsqueda: ' + (xhr.responseJSON?.errorMessage || error));
                    },
                    timeout: 30000
                });
            }

            procesarYMostrarRemitentes(datos, fecha) {
                this.datosOriginales = datos;

                // Contar remitentes
                const conteoRemitentes = {};
                datos.forEach(item => {
                    const remitente = item.PrimerRemitente || 'Sin nombre';
                    if (!conteoRemitentes[remitente]) {
                        conteoRemitentes[remitente] = [];
                    }
                    conteoRemitentes[remitente].push(item);
                });

                this.remitentesPorNombre = conteoRemitentes;

                // Mostrar información de fecha
                //const fechaFormateada = new Date(fecha).toLocaleDateString('es-ES', {
                //    day: '2-digit',
                //    month: 'short',
                //    year: 'numeric'
                //});
                //$('#fechaInfo').text(`📅 ${fechaFormateada}`).removeClass('hidden');

                // Mostrar total de correos
                $('#totalCorreos').text(`${datos.length} correos`);

                // Generar lista de remitentes
                const remitentesHtml = Object.entries(conteoRemitentes)
                    .sort(([, a], [, b]) => b.length - a.length) // Ordenar por cantidad desc
                    .map(([nombre, cotizaciones]) => `
                        <div class="flex items-center justify-between bg-gray-50 rounded p-2 hover:bg-gray-100 transition-colors">
                            <div class="flex items-center space-x-2 flex-1">
                                <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
                                <span class="text-xs font-medium text-gray-800 truncate">${nombre}</span>
                                <span class="text-xs bg-blue-100 text-blue-800 px-1.5 py-0.5 rounded-full font-medium">${cotizaciones.length}</span>
                            </div>
                            <button class="btn-mini bg-green-500 hover:bg-green-600 text-white rounded ml-2 transition-colors" 
                                    onclick="contadorRemitentes.mostrarDetalle('${nombre}')">
                                👁️ Ver
                            </button>
                        </div>
                    `).join('');

                $('#remitentesContainer').html(remitentesHtml);
                $('#remitentesList').removeClass('hidden');
            }

            mostrarDetalle(nombreRemitente) {
                const cotizaciones = this.remitentesPorNombre[nombreRemitente] || [];

                $('#remitenteSeleccionado').text(nombreRemitente);

                const cotizacionesHtml = cotizaciones.map(cot => `
         <tr class="hover:bg-gray-50">
             <td class="font-mono text-blue-600">${cot.Id_CorreoCotizaciones}</td>
