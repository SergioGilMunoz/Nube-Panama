        function anularCotizacion(idCotizacion, botonClickeado) {
            Swal.fire({
                title: 'Anulación de Cotización',
                input: 'text',
                inputLabel: 'Motivo de la anulación',
                inputPlaceholder: 'Escribe el motivo aquí...',
                showCancelButton: true,
                confirmButtonText: 'Anular',
                cancelButtonText: 'Cancelar',
                inputValidator: (value) => {
                    if (!value) {
                        return 'Debes ingresar un motivo.';
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const motivo = result.value;

                    $.ajax({
                        url: '/DASHBOARDSTYLE2/anulaCotizacion', // Cambia esto por tu ruta real
                        type: 'POST',
                        data: {
                            idCotizacion: idCotizacion,
                            mensaje: motivo
                        },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Éxito', 'La cotización fue anulada correctamente.', 'success');
                                $(botonClickeado).closest('tr').addClass('d-none');
                                // Aquí puedes refrescar la lista o hacer otra acción
                            } else {
                                Swal.fire('Error', response.message || 'No se pudo anular la cotización.', 'error');
                            }
                        },
                        error: function (xhr, status, error) {
                            Swal.fire('Error de red', error, 'error');
                        }
                    });
                }
            });
        }



