        function capitalizeWords(str) {
            return str.toLowerCase().replace(/\b\w/g, function (char) {
                return char.toUpperCase();
            });
        }

        function mensajePredeterminado(a) {

            const telefonoChat = document.getElementById("telefonoChat").value;

            if (a == 1) {
                if (telefonoChat.toLowerCase().includes('no se encontró teléfono')) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Número de teléfono requerido',
                        text: 'Por favor, coloque un número de teléfono antes de continuar.',
                    });
                    return; // Detiene la ejecución del resto del bloque
                }

                var idCotizacion = $('#idCotizacionMensaje').text();
                var counterCliente = $('#counterCLiente').text();
                // Crear el mensaje personalizado con formato
                var mensaje = `<b>Estimado Cliente:</b> <i>${counterCliente}</i>, dándole seguimiento a la cotización <b>#${idCotizacion}</b>, por favor informar si esta vigente o si se le da de baja de nuestro sistema.`;
                document.getElementById("chat-input").value = mensaje
                // Simular el clic en el botón de enviar
                $('.chat-send').trigger('click');
            } else if (a == 2) {
                if (telefonoChat.toLowerCase().includes('no se encontró teléfono')) {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Número de teléfono requerido',
                        text: 'Por favor, coloque un número de teléfono antes de continuar.',
                    });
                    return; // Detiene la ejecución del resto del bloque
                }
                var url = $('#url').text();
                document.getElementById("chat-input").value = url
                // Simular el clic en el botón de enviar
                $('.chat-send').trigger('click');
            } else if (a == 3) {
                var url = $('#url').text();
                var counterCliente = $('#counterCLiente').text(); // Obtener el cliente
                var mensajeExtra = `Para brindarle el mejor servicio, deseamos darle seguimiento a la siguiente cotización que mantenemos en sistema. Se le agradece Mantener la cotización o anular la misma si el cliente ha desistido.`;
                var mensajeDescarga = "Para poder descargar la Cotización, darle clic al siguiente link:";

                // Insertar el mensaje adicional primero con "Estimado Cliente: <i>nombre</i>"
                quill.insertText(0, "Estimado Cliente: ", { bold: true });
                quill.insertText(quill.getLength(), `${counterCliente}\n\n`, { italic: true });

                // Insertar el resto del mensaje
                quill.insertText(quill.getLength(), mensajeExtra + "\n\n");

                // Insertar el mensaje de descarga después
                quill.insertText(quill.getLength(), mensajeDescarga + "\n", { bold: true });

                // Insertar la URL con un enlace al final
                quill.insertText(quill.getLength(), url + "\n", { link: url });
            }
