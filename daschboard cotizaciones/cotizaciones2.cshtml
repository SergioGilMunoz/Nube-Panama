        function BuscarCotizacionesVencidas() {
            const clientesSeleccionados = $('#clienteBusquedaCotizacionesVencidasMultiple').val() || [];
            const fechaSeleccionada = $('#fechaCotizacionesVencidas').val();

            // Validación mínima: debe haber al menos un cliente seleccionado
            if (clientesSeleccionados.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Sin clientes seleccionados',
                    text: 'Debes seleccionar al menos un cliente para continuar.',
                    confirmButtonText: 'Entendido',
                });
                return;
            }

            

            // ✅ Si hay fecha, enviar al backend por AJAX
            if (fechaSeleccionada) {
                let periodo1 = "", periodo2 = "";
                const fechas = fechaSeleccionada.split(' al ');
                periodo1 = fechas[0].trim();
                periodo2 = fechas.length > 1 ? fechas[1].trim() : "";

                const tbody = $('#clientesBody');
                tbody.empty();
                $('.noresultCotizacionesVencidas').show();

                $.ajax({
                    type: 'POST',
                    url: '/DASHBOARDSTYLE2/ClienteBusquedaInical2',
                    data: {
                        cliente: clientesSeleccionados.join(','),
                        periodo1: periodo1,
                        periodo2: periodo2
                    },
                    traditional: true,
                    success: function (response) {
                        if (response.success) {
                            renderTablaCotizacionesVencidas(response.data, response.rutaImagenNombreId);
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error en la solicitud',
                                text: 'Hubo un problema en el servidor. Intente nuevamente.',
                                confirmButtonText: 'Cerrar',
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error en la solicitud',
                            text: 'Hubo un problema al procesar la solicitud. Intente nuevamente.',
                            confirmButtonText: 'Cerrar',
                        });
                        console.error('Error en la solicitud:', error);
                    }
                });

            } else {
                // ✅ Si NO hay fecha → buscar en el DOM (filtrado frontend)
                clientesSeleccionados.forEach(clienteId => {
                    const filaCliente = $(`tr[data-id-cliente='${clienteId}']`);
                    if (filaCliente.length) {
                        filaCliente.show();
                    }
                });

                // Ocultar las demás filas que no coincidan
                $('tr[data-id-cliente]').each(function () {
                    const id = $(this).data('id-cliente');
                    if (!clientesSeleccionados.includes(id.toString())) {
                        $(this).hide();
                    }
                });

                $('.noresultCotizacionesVencidas').hide(); // Oculta mensaje "sin resultados"
            }
        }

      

